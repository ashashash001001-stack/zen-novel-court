---
interface Props {
  novelData?: Record<string, {
    title: string;
    author: string;
    totalChapters: number;
    currentChapter: number;
  }>;
}

const { novelData = {} } = Astro.props;
---

<section class="continue-reading" data-has-progress={Object.keys(novelData).length > 0}>
  {Object.keys(novelData).length > 0 ? (
    <div class="continue-reading-card">
      <h3 class="continue-title">繼續閱讀</h3>
      {Object.entries(novelData).map(([slug, data]) => (
        <a href={`/book/${slug}`} class="continue-item">
          <div class="continue-info">
            <span class="continue-novel-title">{data.title}</span>
            <span class="continue-chapter">第 {data.currentChapter} 章 / 共 {data.totalChapters} 章</span>
          </div>
          <div class="continue-progress">
            <div class="progress-bar">
              <div class="progress-fill" style={`width: ${(data.currentChapter / data.totalChapters) * 100}%`}></div>
            </div>
            <span class="progress-percent">{Math.round((data.currentChapter / data.totalChapters) * 100)}%</span>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="continue-reading-empty">
      <h3 class="continue-title">繼續閱讀</h3>
      <p class="empty-text">暫無閱讀記錄</p>
      <a href="/library" class="empty-link">探索小說 →</a>
    </div>
  )}
</section>

<style>
  .continue-reading {
    padding: var(--spacing-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    box-shadow: var(--bento-shadow);
  }

  .continue-reading[data-has-progress="false"] {
    text-align: center;
    padding: var(--spacing-6);
  }

  .continue-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-3);
    font-family: var(--font-serif);
  }

  .continue-item {
    display: block;
    text-decoration: none;
    padding: var(--spacing-3);
    background: var(--color-bg-inner);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-2);
    transition: var(--bento-transition);
  }

  .continue-item:last-child {
    margin-bottom: 0;
  }

  @media (hover: hover) {
    .continue-item:hover {
      background: var(--color-accent-light);
    }
  }

  .continue-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-2);
  }

  .continue-novel-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
  }

  .continue-chapter {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .continue-progress {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  .progress-bar {
    flex: 1;
    height: 6px;
    background: var(--color-bg-outer);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: width var(--t-normal) var(--ease-smooth);
  }

  .progress-percent {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    min-width: 36px;
    text-align: right;
  }

  .empty-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-3);
  }

  .empty-link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (hover: hover) {
    .empty-link:hover {
      text-decoration: underline;
    }
  }
</style>

<script>
  function initContinueReading() {
    const continueSection = document.querySelector('.continue-reading');
    if (!continueSection) return;

    try {
      const readingData = localStorage.getItem('reading_progress');
      if (!readingData) {
        continueSection.setAttribute('data-has-progress', 'false');
        return;
      }

      const progress = JSON.parse(readingData);
      if (!progress || Object.keys(progress).length === 0) {
        continueSection.setAttribute('data-has-progress', 'false');
        return;
      }

      continueSection.setAttribute('data-has-progress', 'true');
    } catch (e) {
      console.warn('Failed to read reading progress:', e);
      continueSection.setAttribute('data-has-progress', 'false');
    }
  }

  document.addEventListener('DOMContentLoaded', initContinueReading);
</script>