---
// Client-side only - reading progress loaded from localStorage
---

<section class="continue-reading" id="continue-reading-section">
  <!-- Content rendered client-side -->
</section>

<style>
  .continue-reading {
    padding: var(--spacing-4);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    box-shadow: var(--bento-shadow);
  }

  .continue-reading[data-has-progress="false"] {
    text-align: center;
    padding: var(--spacing-6);
  }

  .continue-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-3);
    font-family: var(--font-serif);
  }

  .continue-item {
    display: block;
    text-decoration: none;
    padding: var(--spacing-3);
    background: var(--color-bg-inner);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-2);
    transition: var(--bento-transition);
  }

  .continue-item:last-child {
    margin-bottom: 0;
  }

  @media (hover: hover) {
    .continue-item:hover {
      background: var(--color-accent-light);
    }
  }

  .continue-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-2);
  }

  .continue-novel-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
  }

  .continue-chapter {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .continue-progress {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  .progress-bar {
    flex: 1;
    height: 6px;
    background: var(--color-bg-outer);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: width var(--t-normal) var(--ease-smooth);
  }

  .progress-percent {
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    min-width: 36px;
    text-align: right;
  }

  .empty-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-3);
  }

  .empty-link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (hover: hover) {
    .empty-link:hover {
      text-decoration: underline;
    }
  }
</style>

<script>
  // Book data - could be passed from server or loaded from embedded data
  const bookData = {};

  // Get base path from window.__configBase__ (set by BaseLayout)
  const BASE_PATH = typeof window !== 'undefined' ? (window.__configBase__ || '') : '';

  function initContinueReading() {
    const continueSection = document.querySelector('#continue-reading-section');
    if (!continueSection) return;

    try {
      // Try to read reading progress from the page (embedded by server)
      const readingProgressEl = document.getElementById('reading-progress-data');
      let progress = {};
      
      if (readingProgressEl) {
        progress = JSON.parse(readingProgressEl.textContent || '{}');
      } else {
        // Fallback: try localStorage (for client-only state)
        const localData = localStorage.getItem('reading_progress');
        if (localData) {
          progress = JSON.parse(localData);
        }
      }

      // Also check for lastReadBook (legacy format)
      const lastReadBook = localStorage.getItem('lastReadBook');
      if (lastReadBook && !progress) {
        try {
          const lr = JSON.parse(lastReadBook);
          if (lr.bookId) {
            progress[lr.bookId] = { currentChapter: lr.chapter || 1 };
          }
        } catch (e) {}
      }

      const entries = Object.entries(progress);
      if (entries.length === 0) {
        // Empty state
        continueSection.innerHTML = `
          <div class="continue-reading-empty">
            <h3 class="continue-title">继续阅读</h3>
            <p class="empty-text">暂无阅读记录</p>
            <a href="${BASE_PATH}/library" class="empty-link">探索小说 →</a>
          </div>
        `;
        return;
      }

      // Get book metadata from embedded data
      const booksMetaEl = document.getElementById('books-meta');
      const booksMeta = booksMetaEl ? JSON.parse(booksMetaEl.textContent || '{}') : {};

      let html = '<div class="continue-reading-card"><h3 class="continue-title">继续阅读</h3>';
      
      for (const [bookId, data] of entries) {
        const meta = booksMeta[bookId] || {};
        const title = meta.title || bookId;
        const totalChapters = meta.totalChapters || data.totalChapters || 1;
        const currentChapter = data.currentChapter || data.chapter || 1;
        const percent = Math.round((currentChapter / totalChapters) * 100);

        html += `
          <a href="${BASE_PATH}/book/${bookId}" class="continue-item">
            <div class="continue-info">
              <span class="continue-novel-title">${title}</span>
              <span class="continue-chapter">第 ${currentChapter} 章 / 共 ${totalChapters} 章</span>
            </div>
            <div class="continue-progress">
              <div class="progress-bar">
                <div class="progress-fill" style="width: ${percent}%"></div>
              </div>
              <span class="progress-percent">${percent}%</span>
            </div>
          </a>
        `;
      }
      
      html += '</div>';
      continueSection.innerHTML = html;
    } catch (e) {
      console.warn('Failed to init continue reading:', e);
      const continueSection = document.querySelector('#continue-reading-section');
      if (continueSection) {
        continueSection.innerHTML = `
          <div class="continue-reading-empty">
            <h3 class="continue-title">继续阅读</h3>
            <p class="empty-text">暂无阅读记录</p>
            <a href="${BASE_PATH}/library" class="empty-link">探索小说 →</a>
          </div>
        `;
      }
    }
  }

  // Run on DOMContentLoaded and also after view transitions
  document.addEventListener('DOMContentLoaded', initContinueReading);
  
  // Also re-run after Astro view transitions
  document.addEventListener('astro:page-load', initContinueReading);
</script>