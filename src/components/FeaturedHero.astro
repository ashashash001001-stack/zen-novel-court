---
interface Props {
  novel: {
    slug: string;
    title: string;
    author: string;
    genre: string;
    status: string;
    synopsis: string;
    totalChapters: number;
    cover?: string;
  };
}

const { novel } = Astro.props;
const { config } = await import('../config');
---

<section class="featured-hero">
  <!-- Hero Background Image -->
  <div class="hero-background">
    <img src="/images/hero-bamboo-16x9.png" alt="竹林閱讀空間" />
  </div>
  <a href={config.path('/book/' + novel.slug)} class="hero-link" aria-label={`查看《${novel.title}》詳情`}></a>

  <div class="hero-cover">
    {novel.cover ? (
      <img src={novel.cover} alt={`${novel.title}封面`} class="hero-cover-image" />
    ) : (
      <div class="css-book-cover" style="width: 100%; height: 100%; min-height: 280px;">
        <div class="cover-content">
          <span class="cover-title">{novel.title}</span>
          <span class="cover-author">{novel.author}</span>
        </div>
      </div>
    )}
    <span class={`status-badge ${novel.status === '已完結' ? 'status-done' : 'status-ongoing'}`}>
      {novel.status}
    </span>
  </div>

  <div class="hero-content">
    <span class="hero-badge">精選推薦</span>
    <h1 class="hero-title">{novel.title}</h1>
    <p class="hero-author">作者：{novel.author}</p>
    <p class="hero-meta">
      <span class="hero-genre">{novel.genre?.split('/')[0]}</span>
      <span class="hero-divider">·</span>
      <span class="hero-chapters">{novel.totalChapters}章</span>
    </p>
    <p class="hero-synopsis">{novel.synopsis}</p>

    <div class="hero-actions">
      <a href={config.path('/book/' + novel.slug + '/1')} class="btn btn-primary" data-hotkey="r">
        <span>開始閱讀</span>
      </a>
      <a href={config.path('/library')} class="btn btn-secondary hero-search-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span>搜尋</span>
      </a>
    </div>
  </div>
</section>

<style>
  .featured-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bento-gap-lg, var(--spacing-6));
    padding: var(--spacing-6) var(--page-padding-x);
    min-height: 320px;
    position: relative;
    overflow: hidden;
  }

  /* Hero Background Image */
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
  }

  .hero-link {
    position: absolute;
    inset: 0;
    z-index: 10;
    text-decoration: none;
  }

  .hero-link:hover ~ .hero-cover,
  .hero-link:hover ~ .hero-content .hero-title {
    /* visual feedback handled by grid hover */
  }

  @media (min-width: 768px) {
    .featured-hero:has(.hero-link:hover) {
    }

    .featured-hero:has(.hero-link:hover) .hero-cover,
    .featured-hero:has(.hero-link:hover) .hero-content {
      opacity: 0.85;
    }

    .featured-hero:has(.hero-link:hover) .hero-cover {
      transform: scale(0.98);
    }

    .featured-hero:has(.hero-link:hover) .hero-content .hero-title {
      color: var(--color-accent);
    }
  }

  @media (min-width: 768px) {
    .featured-hero {
      grid-template-columns: 280px 1fr;
      padding: var(--spacing-8);
    }
  }

  .hero-cover {
    position: relative;
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
  }

  .hero-cover-image {
    width: 100%;
    height: 100%;
    min-height: 280px;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  @media (min-width: 768px) {
    .hero-cover {
      margin: 0;
    }
  }

  .css-book-cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-300, #D8CFC4);
    border-radius: var(--radius-sm);
    overflow: hidden;
    font-family: var(--font-serif);
    box-shadow: var(--bento-shadow);
  }

  .css-book-cover::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: rgba(0, 0, 0, 0.12);
    z-index: 1;
  }

  .css-book-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 40%, rgba(0,0,0,0.05) 100%);
    pointer-events: none;
  }

  .cover-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-3);
    color: var(--color-white);
  }

  .cover-title {
    font-size: var(--text-lg);
    font-weight: var(--font-semibold);
    color: var(--color-white);
    line-height: var(--line-height-snug);
    letter-spacing: 0.05em;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
  }

  .cover-author {
    display: block;
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    margin-top: var(--spacing-2);
    font-weight: var(--font-normal);
  }

  .status-badge {
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    z-index: 2;
  }

  .status-badge.status-ongoing {
    background: var(--color-accent);
  }

  .status-badge.status-done {
    background: var(--color-success, #7d9a7d);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;
    position: relative;
    z-index: 1;
    padding: var(--spacing-4);
    background: rgba(253, 251, 247, 0.85);
    border-radius: var(--radius-lg);
  }

  @media (min-width: 768px) {
    .hero-content {
      text-align: left;
    }
  }

  .hero-badge {
    display: inline-block;
    padding: var(--spacing-1) var(--spacing-3);
    background: var(--color-accent);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--spacing-4);
  }

  .hero-title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    font-family: var(--font-serif);
    margin: 0 0 var(--spacing-2);
    letter-spacing: -0.01em;
  }

  .hero-author {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-2);
  }

  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--spacing-4);
  }

  @media (min-width: 768px) {
    .hero-meta {
      justify-content: flex-start;
    }
  }

  .hero-divider {
    opacity: 0.5;
  }

  .hero-genre {
    color: var(--color-accent);
    font-weight: var(--font-medium);
  }

  .hero-synopsis {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--spacing-6);
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: var(--spacing-3);
    justify-content: center;
    position: relative;
    z-index: 20;
  }

  @media (min-width: 768px) {
    .hero-actions {
      justify-content: flex-start;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-3) var(--spacing-6);
    min-height: 44px;
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: var(--bento-transition);
    text-decoration: none;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-white);
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
    box-shadow: var(--bento-shadow-hover);
  }

  .btn-secondary {
    background: var(--color-bg-inner);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-default);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<script>
  document.querySelectorAll('.btn-secondary[data-novel-slug]').forEach(btn => {
    btn.addEventListener('click', () => {
      const slug = btn.getAttribute('data-novel-slug');
      let shelf = JSON.parse(localStorage.getItem('bookshelf') || '[]');
      if (!shelf.includes(slug)) {
        shelf.push(slug);
        localStorage.setItem('bookshelf', JSON.stringify(shelf));
        btn.textContent = '已加入';
        (btn as HTMLElement).style.opacity = '0.7';
      }
    });
  });
</script>