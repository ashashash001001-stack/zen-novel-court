---
interface Props {
  hotRankings: Array<{
    slug: string;
    title: string;
    author: string;
    genre: string;
    synopsis: string;
    chapters: number;
    cover: string | null;
  }>;
  latestUpdates: Array<{
    slug: string;
    title: string;
    genre: string;
    synopsis: string;
    status: string;
    chapters: number;
    cover: string | null;
  }>;
}

const { hotRankings = [], latestUpdates = [] } = Astro.props;
const { config } = await import('../config');
---

<section class="bento-grid">
  <div class="bento-cell bento-rank">
    <h3 class="bento-title">熱門排行</h3>
    <ul class="ranking-list">
      {hotRankings.slice(0, 4).map((novel) => (
        <li class="ranking-card">
          <a href={config.path('/book/' + novel.slug)} class="ranking-card-link">
            <div class="ranking-cover">
              {novel.cover ? (
                <img src={novel.cover} alt="" class="cover-img" loading="lazy" />
              ) : (
                <div class="cover-fallback">{novel.title.charAt(0)}</div>
              )}
            </div>
            <div class="ranking-content">
              <span class="ranking-title">{novel.title}</span>
              <span class="ranking-synopsis">{novel.synopsis}</span>
              <span class="ranking-genre">{novel.genre}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="bento-cell bento-updates">
    <h3 class="bento-title">最新更新</h3>
    <ul class="ranking-list">
      {latestUpdates.slice(0, 4).map((novel) => (
        <li class="ranking-card">
          <a href={config.path('/book/' + novel.slug)} class="ranking-card-link">
            <div class="ranking-cover">
              {novel.cover ? (
                <img src={novel.cover} alt="" class="cover-img" loading="lazy" />
              ) : (
                <div class="cover-fallback">{novel.title.charAt(0)}</div>
              )}
            </div>
            <div class="ranking-content">
              <span class="ranking-title">{novel.title}</span>
              <span class="ranking-synopsis">{novel.synopsis}</span>
              <span class="ranking-genre">{novel.genre}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="bento-cell bento-cats">
    <h3 class="bento-title">探索分類</h3>
    <div class="cat-grid">
      <a href={config.path('/category/healing')} class="cat-chip">療癒</a>
      <a href={config.path('/category/food')} class="cat-chip">美食</a>
      <a href={config.path('/category/urban')} class="cat-chip">都市</a>
      <a href={config.path('/category/system')} class="cat-chip">系統</a>
      <a href={config.path('/category/growth')} class="cat-chip">成長</a>
      <a href={config.path('/library')} class="cat-chip cat-more">更多 →</a>
    </div>
  </div>

  <div class="bento-cell bento-stats">
    <h3 class="bento-title">站點統計</h3>
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-num">{hotRankings.length + latestUpdates.length}</span>
        <span class="stat-label">作品總數</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">{hotRankings.reduce((acc, n) => acc + (n.chapters || 0), 0)}</span>
        <span class="stat-label">總章節數</span>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--bento-gap);
    padding: var(--spacing-6) var(--page-padding-x);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .bento-cell {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    padding: var(--spacing-4);
    box-shadow: var(--bento-shadow);
    transition: var(--bento-transition);
  }

  @media (hover: hover) {
    .bento-cell:hover {
      box-shadow: var(--bento-shadow-hover);
      transform: translateY(-2px);
    }
  }

  .bento-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--spacing-3);
    font-family: var(--font-serif);
  }

  .ranking-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .ranking-card {
    margin: 0;
  }

  .ranking-card-link {
    display: flex;
    gap: var(--spacing-3);
    text-decoration: none;
    padding: var(--spacing-2);
    border-radius: var(--radius-md);
    transition: var(--bento-transition);
  }

  @media (hover: hover) {
    .ranking-card-link:hover {
      background: var(--color-accent-light);
    }
  }

  /* Tap/active feedback for touch devices */
  .ranking-card-link:active {
    transform: scale(0.98);
    opacity: 0.9;
    transition: transform 0.1s ease-out, opacity 0.1s ease-out;
  }

  .ranking-cover {
    width: 48px;
    height: 64px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-bg-inner);
  }

  .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cover-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    font-family: var(--font-serif);
  }

  .ranking-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .ranking-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ranking-synopsis {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
  }

  .ranking-genre {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: var(--font-medium);
  }

  .cat-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .cat-chip {
    display: inline-flex;
    align-items: center;
    padding: var(--spacing-2) var(--spacing-3);
    background: var(--color-accent-light);
    color: var(--color-text-primary);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--bento-transition);
  }

  @media (hover: hover) {
    .cat-chip:hover {
      background: var(--color-accent);
      color: var(--color-white);
    }
  }

  .cat-chip.cat-more {
    background: var(--color-bg-inner);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-3);
  }

  .stat-item {
    text-align: center;
    padding: var(--spacing-3);
    background: var(--color-bg-inner);
    border-radius: var(--radius-md);
  }

  .stat-num {
    display: block;
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-accent);
    font-family: var(--font-serif);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>