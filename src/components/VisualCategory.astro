---
import { categoryConfig } from '../config/categories';
import { config } from '../config';

const categories = Object.entries(categoryConfig).map(([slug, data]) => ({
  name: data.name,
  slug,
  icon: data.icon,
  color: data.color
}));
---

<section class="visual-categories">
  {categories.map((cat) => (
    <a href={config.path('/category/' + cat.slug)} class="cat-card" style={`background: ${cat.color}`}>
      <span class="cat-icon">{cat.icon}</span>
      <span class="cat-name">{cat.name}</span>
    </a>
  ))}
</section>

<style>
  .visual-categories {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--bento-gap);
    padding: var(--spacing-4) var(--page-padding-x);
  }

  @media (min-width: 640px) {
    .visual-categories {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .visual-categories {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .cat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    border-radius: var(--bento-radius);
    text-decoration: none;
    transition: var(--bento-transition);
    box-shadow: var(--bento-shadow);
    padding: var(--spacing-4);
  }

  @media (hover: hover) {
    .cat-card:hover {
      transform: translateY(-4px) scale(1.03);
      box-shadow: var(--bento-shadow-hover);
    }
  }

  .cat-icon {
    font-size: var(--text-2xl);
    margin-bottom: var(--spacing-1);
  }

  .cat-name {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-white);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }
</style>