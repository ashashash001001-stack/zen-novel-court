---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getCollection } from 'astro:content';

const novels = await getCollection('novels');
const novelData = novels
  .filter(n => n.data.synopsis)
  .map(n => ({
    slug: n.slug,
    ...n.data
  }));

const categories = [
  { name: '療癒', slug: 'healing', icon: '🌿', color: '#7d9a7d' },
  { name: '美食', slug: 'food', icon: '🍜', color: '#b8a86b' },
  { name: '都市', slug: 'urban', icon: '🏙️', color: '#6b7a8f' },
  { name: '系統', slug: 'system', icon: '⚡', color: '#8b7dab' },
  { name: '成長', slug: 'growth', icon: '📈', color: '#b08b8b' },
  { name: '其他', slug: 'other', icon: '📚', color: '#7a7a7a' }
];
---

<BaseLayout title="小说阁 - 沉浸阅读，从这里开始" activeTab="home">
  <!-- Hero Section -->
  <section class="home-hero">
    <div class="hero-content">
      <span class="hero-badge">精選推薦</span>
      <a href={config.path('/library')} class="hero-search-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span>搜尋小說、作者...</span>
      </a>
      <div class="hero-stats">
        <div class="hero-stat">
       <span class="hero-stat-num">{novelData.length}</span>
       <span class="hero-stat-label">精選作品</span>
     </div>
     <div class="hero-stat">
       <span class="hero-stat-num">{novelData.reduce((acc, n) => acc + n.chapters, 0)}</span>
       <span class="hero-stat-label">總章節數</span>
     </div>

      </div>
    </div>
  </section>

  <!-- Featured Section - Horizontal Scroll -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title">精選推薦</h2>
    </div>
    <div class="featured-scroll hide-scrollbar">
      {novelData.map((novel, index) => (

        <a href={config.path('/book/' + novel.slug)} class="featured-card" style={`animation-delay: ${index * 0.05}s`}>
          <div class="book-cover-wrapper">
            <div class="css-book-cover" style="width: 140px; height: 200px;">
              <div class="cover-content">
                <span class="cover-title">{novel.title}</span>
                <span class="cover-author">{novel.author}</span>
              </div>
            </div>
            <span class={`status-badge ${novel.status === '已完結' ? 'status-done' : 'status-ongoing'}`}>
              {novel.status}
            </span>
          </div>
          <div class="featured-info">
            <div class="featured-title">{novel.title}</div>
            <div class="featured-meta">
              <span>{novel.chapters}章</span>
              <span>•</span>
              <span>{novel.genre.split('/')[0]}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Category Grid -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title">分類</h2>
      <a href={config.path('/shelf')} class="section-more">查看全部</a>
    </div>
    <div class="cat-grid">
      {categories.map((cat, index) => (
        <a href={config.path('/category/' + cat.slug)} class={`cat-item ${index === 0 ? 'featured' : ''}`}>
          <span class="cat-icon">{cat.icon}</span>
          <span class="cat-name">{cat.name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Ranking Section -->
  <section class="home-section">
    <div class="section-header">
      <h2 class="section-title">熱門排行</h2>
    </div>
    <div class="rank-tabs">
      <button class="rank-tab active">綜合</button>
      <button class="rank-tab">熱度</button>
      <button class="rank-tab">推薦</button>
    </div>
    <div class="rank-list">
      {novelData.map((novel, index) => (

        <a href={config.path('/book/' + novel.slug)} class="rank-item" style={`animation-delay: ${index * 0.02}s`}>
          <span class={`rank-num ${index < 3 ? 'rank-top' : ''}`}>{index + 1}</span>
          <div class="css-book-cover-mini" style="width: 50px; height: 70px;">
            <div class="cover-content">
              <span class="cover-title" style="font-size: var(--text-xs-sm);">{novel.title.slice(0, 2)}</span>
            </div>
          </div>
          <div class="rank-info">
            <div class="rank-title">{novel.title}</div>
            <div class="rank-sub">{novel.author} • {novel.chapters}章</div>
          </div>
          <span class="rank-score">{novel.chapters}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Updates -->
  <section class="home-section home-section-last">
    <div class="section-header">
      <h2 class="section-title">最新更新</h2>
    </div>
    <div class="latest-list">
      {novels.map((novel) => (
        <a href={config.path('/book/' + novel.slug)} class="latest-item">
          <div class="css-book-cover-mini" style="width: 40px; height: 56px; flex-shrink: 0;">
            <div class="cover-content">
              <span class="cover-title" style="font-size: 10px;">{novel.title.slice(0, 2)}</span>
            </div>
          </div>
          <div class="latest-info">
            <div class="latest-title">{novel.title}</div>
            <div class="latest-chapter">{novel.status} • {novel.chapters}章</div>
          </div>
          <span class="latest-time">{novel.genre.split('/')[0]}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ===========================================
     Hero Section - Clean & Focused
  =========================================== */
  .home-hero {
    position: relative;
    margin: 0;
    padding: var(--spacing-10) var(--page-padding-x);
    background: linear-gradient(180deg, var(--color-bg-inner) 0%, var(--color-bg-outer) 100%);
    overflow: hidden;
    min-height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    animation: hero-enter 0.5s ease-out;
    width: 100%;
    max-width: 480px;
  }

  @keyframes hero-enter {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-badge {
    display: inline-block;
    padding: var(--spacing-1) var(--spacing-3);
    background: var(--color-accent);
    color: var(--color-white);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    margin-bottom: var(--spacing-4);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-3);
    padding: var(--spacing-4) var(--spacing-6);
    background: var(--color-bg-inner);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    color: var(--color-text-muted);
    font-size: var(--text-base);
    font-weight: var(--font-normal);
    margin-bottom: var(--spacing-6);
    max-width: 400px;
    transition: all var(--t-normal);
    box-shadow: var(--shadow-xs);
    text-decoration: none;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-search-btn:hover {
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
    color: var(--color-text-primary);
    border-color: var(--color-accent);
  }

  .hero-search-btn:active {
    transform: scale(0.98);
  }

  .hero-stats {
    display: flex;
    gap: var(--spacing-4);
    justify-content: center;
  }

  .hero-stat {
    text-align: center;
    flex: 1;
    padding: var(--spacing-3) var(--spacing-4);
    background: var(--color-bg-inner);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    transition: all var(--t-normal);
    max-width: 140px;
  }

  .hero-stat:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .hero-stat-num {
    display: block;
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    font-family: var(--font-serif);
    font-variant-numeric: tabular-nums;
  }

  .hero-stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
    letter-spacing: 0.02em;
    margin-top: var(--spacing-1);
  }

  /* Section Layout */
  .home-section {
    padding: var(--spacing-8) 0 0;
    animation: section-enter 0.4s ease-out both;
  }

  .home-section:nth-child(2) { animation-delay: 0.05s; }
  .home-section:nth-child(3) { animation-delay: 0.1s; }
  .home-section:nth-child(4) { animation-delay: 0.15s; }
  .home-section:nth-child(5) { animation-delay: 0.2s; }

  @keyframes section-enter {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .home-section-last {
    padding-bottom: var(--spacing-8);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--page-padding-x);
    margin-bottom: var(--spacing-4);
  }

  .section-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0;
    padding: 0;
    font-family: var(--font-serif);
  }

  .section-more {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--font-medium);
    transition: color var(--t-fast);
  }

  .section-more:hover {
    color: var(--color-accent);
  }

  /* Featured Cards - Horizontal Scroll */
  .featured-scroll {
    display: flex;
    gap: var(--spacing-4);
    overflow-x: auto;
    padding: 0 var(--page-padding-x) var(--spacing-4);
    padding-right: calc(var(--spacing-4) + 60px);
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .featured-scroll::-webkit-scrollbar {
    display: none;
  }

  .featured-card {
    flex-shrink: 0;
    width: 140px;
    scroll-snap-align: start;
    background: var(--color-bg-inner);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xs);
    transition: all var(--t-normal);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    animation: card-enter 0.4s ease-out both;
    text-decoration: none;
  }

  @keyframes card-enter {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .featured-card:active {
    transform: scale(0.98);
  }

  @media (hover: hover) {
    .featured-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md);
    }
  }

  .book-cover-wrapper {
    position: relative;
    display: block;
  }

  .css-book-cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-300, #D8CFC4);
    border-radius: var(--radius-sm);
    overflow: hidden;
    font-family: var(--font-serif);
    box-shadow: var(--shadow-md);
  }

  .css-book-cover::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: rgba(0, 0, 0, 0.12);
    z-index: 1;
  }

  .css-book-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 40%, rgba(0,0,0,0.05) 100%);
    pointer-events: none;
  }

  .cover-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-3);
    color: var(--color-white);
  }

  .cover-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-white);
    line-height: var(--line-height-snug);
    letter-spacing: 0.05em;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
  }

  .cover-author {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.85);
    margin-top: var(--spacing-1);
    font-weight: var(--font-normal);
    letter-spacing: 0.02em;
  }

  .status-badge {
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    min-height: 44px;
    min-width: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    z-index: 2;
  }

  .status-badge.status-ongoing {
    background: var(--accent);
  }

  .status-badge.status-done {
    background: var(--color-success, #7d9a7d);
  }

  .featured-info {
    padding: var(--spacing-2) var(--spacing-3);
  }

  .featured-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 4px;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Category Grid */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-4);
    padding: 0 var(--page-padding-x);
  }

  .cat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    gap: var(--spacing-2);
    background: var(--color-bg-inner);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text-dark);
    transition: all var(--t-normal);
  }

  .cat-item {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: var(--spacing-5);
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: transform var(--t-fast) var(--ease-elastic), box-shadow var(--t-fast) var(--ease-smooth);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border-subtle);
    min-height: 100px;
  }

  .cat-item:active {
    transform: scale(0.96);
    transition: transform 0.1s var(--ease-elastic);
  }

  @media (hover: hover) {
    .cat-item:hover {
      transform: translateY(-4px) scale(1.02);
      box-shadow: var(--shadow-md);
    }
  }

  .cat-item.featured {
    grid-column: span 2;
    flex-direction: row;
    justify-content: flex-start;
    gap: var(--spacing-4);
    padding: var(--spacing-6);
  }

  .cat-icon {
    font-size: var(--text-icon-sm);
    margin-bottom: var(--spacing-2);
  }

  .cat-item.featured .cat-icon {
    font-size: var(--text-icon-lg);
    margin-bottom: 0;
  }

  .cat-name {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-muted);
    text-align: center;
  }

  .cat-item.featured .cat-name {
    font-size: var(--text-base);
    color: var(--color-text-primary);
  }

  /* Ranking Section */
  .rank-tabs {
    display: flex;
    gap: var(--spacing-2);
    padding: 0 var(--page-padding-x);
    margin-bottom: var(--spacing-4);
  }

  .rank-tab {
    padding: var(--spacing-2) var(--spacing-4);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-full);
    background: transparent;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--t-normal);
  }

  .rank-tab.active {
    background: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
  }

  .rank-tab:active {
    transform: scale(0.98);
  }

  .rank-list {
    padding: 0 var(--page-padding-x);
  }

  .rank-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-3);
    background: var(--color-bg-card);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform var(--t-fast) var(--ease-elastic), box-shadow var(--t-fast) var(--ease-smooth);
    animation: rank-enter var(--t-slow) var(--ease-smooth) both;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
  }

  @keyframes rank-enter {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .rank-item:active {
    transform: scale(0.98) translateX(2px);
    transition: transform 0.1s var(--ease-elastic);
  }

  @media (hover: hover) {
    .rank-item:hover {
      transform: translateX(4px);
      box-shadow: var(--shadow-md);
    }
  }

  .rank-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    flex-shrink: 0;
    background: var(--color-bg-inner);
    border: 2px solid var(--color-border-default);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }

  .rank-num.rank-top {
    background: var(--color-accent);
    color: var(--color-white);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-xs);
  }

  .css-book-cover-mini {
    background: var(--color-primary-300, #D8CFC4);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .css-book-cover-mini .cover-title {
    font-size: var(--text-sm);
  }

  .rank-info {
    flex: 1;
    min-width: 0;
  }

  .rank-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rank-sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .rank-score {
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    color: var(--color-accent);
    font-variant-numeric: tabular-nums;
  }

  /* Latest Updates */
  .latest-list {
    display: flex;
    flex-direction: column;
    padding: 0;
  }

  .latest-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-3) var(--page-padding-x);
    border-bottom: 1px solid var(--color-border-subtle);
    transition: all var(--t-fast);
    text-decoration: none;
  }

  .latest-item:active {
    background: var(--color-accent-light);
  }

  @media (hover: hover) {
    .latest-item:hover {
      background: var(--color-accent-light);
    }
  }

  .latest-info {
    flex: 1;
    min-width: 0;
  }

  .latest-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .latest-chapter {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .latest-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  /* Responsive - Tablet (640px+) */
@media (min-width: 640px) {
  .home-hero {
    padding: var(--spacing-16) var(--spacing-8);
    min-height: 320px;
  }

  .hero-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-stats {
    gap: var(--spacing-6);
    max-width: 500px;
    margin: 0 auto;
  }

  .hero-stat {
    max-width: 160px;
  }

  .home-section {
    padding: var(--spacing-8) 0 0;
  }

  .section-header {
    padding: 0 var(--spacing-8);
  }

  .featured-scroll {
    padding: 0 var(--spacing-6) var(--spacing-6);
    padding-right: var(--spacing-6);
  }

  .featured-card {
    width: 160px;
  }

  .cat-grid {
    grid-template-columns: repeat(3, 1fr);
    padding: 0 var(--spacing-8);
  }

  .cat-item {
    min-height: 120px;
  }

  .rank-list {
    padding: 0 var(--spacing-6);
    max-width: 600px;
    margin: 0 auto;
  }
}

/* Responsive - Desktop (1024px+) */
@media (min-width: 1024px) {
  .home-hero {
    padding: var(--spacing-20) var(--spacing-12);
    min-height: 360px;
  }

  .hero-badge {
    font-size: var(--text-base);
  }

  .hero-search-btn {
    max-width: 500px;
    padding: var(--spacing-5) var(--spacing-8);
  }

  .home-section {
    padding: var(--spacing-10) 0 0;
  }

  .section-header {
