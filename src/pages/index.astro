---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getCollection } from 'astro:content';
import FeaturedHero from '../components/FeaturedHero.astro';
import BentoGrid from '../components/BentoGrid.astro';
import ContinueReading from '../components/ContinueReading.astro';
import VisualCategory from '../components/VisualCategory.astro';

const novels = await getCollection('novels');
const novelData = novels
  .filter(n => n.id.endsWith('/meta') && n.data?.synopsis)
  .map(n => ({
    slug: n.id.replace('/meta', ''),
    ...n.data
  }));

const featuredNovel = novelData[0] || { slug: '', title: '', author: '', genre: '', status: '', synopsis: '', totalChapters: 0 };
const hotRankings = novelData.slice(0, 5);
const latestUpdates = novelData.slice(0, 5);

// Build books metadata for client-side reading progress
const booksMeta: Record<string, { title: string; totalChapters: number }> = {};
novelData.forEach(n => {
  booksMeta[n.slug] = { title: n.title, totalChapters: n.totalChapters };
});
const booksMetaJSON = JSON.stringify(booksMeta).replace(/</g, '\\u003c');
---

<BaseLayout title="小說閣 - 沉浸閱讀，從這裡開始" activeTab="home">
  <!-- Books metadata for client-side -->
  <script id="books-meta" type="application/json">{booksMetaJSON}</script>
  
  <FeaturedHero novel={featuredNovel} />
  
  <VisualCategory />
  
  <BentoGrid hotRankings={hotRankings} latestUpdates={latestUpdates} />
  
  <ContinueReading />
</BaseLayout>