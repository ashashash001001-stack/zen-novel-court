---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { config } from '../../../config';

const novels = await getCollection('novels');
const chapters = novels.sort((a, b) => a.data.chapter - b.data.chapter);
---

<BaseLayout title="治愈分类 - 小说阁">
  <div class="page-header">
    <h1>治愈</h1>
    <p>温暖心灵的故事</p>
  </div>

  <div class="book-grid">
    <a href={config.path('/book/佛系廚神')} class="book-card">
      <div class="book-cover"></div>
      <div class="book-info">
        <h3>佛系廚神</h3>
        <p>禅意素食主义</p>
      </div>
    </a>
  </div>
</BaseLayout>

<style>
  .page-header { padding: 1.5rem 1rem; margin-bottom: 2rem; }
  .page-header h1 { font-size: 2rem; font-weight: 700; }
  .page-header p { color: var(--text-light); }
  .book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem; padding: 1rem; }
  .book-card { display: block; border-radius: 0.75rem; overflow: hidden; }
  .book-cover { aspect-ratio: 3/4; background: linear-gradient(145deg, #d4c4b5 0%, #a89880 100%); border-radius: 0.5rem; margin-bottom: 0.75rem; }
  .book-info h3 { font-size: 1rem; font-weight: 600; }
  .book-info p { font-size: 0.85rem; color: var(--text-light); }
</style>