---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
import { getCollection } from 'astro:content';
import { categoryConfig, getAllCategorySlugs } from '../config/categories';
import VisualCategory from '../components/VisualCategory.astro';
import fs from 'fs';
import path from 'path';
import DualImage from '../components/DualImage.astro';

// Novel data - from Content Collection (meta.json)
const novelsCollection = await getCollection('novels');
const novels = novelsCollection
  .filter(n => n.id.endsWith('/meta') && n.data?.title)
  .map(n => {
    const slug = n.id.replace('/meta', '');
    // Check if cover image exists (prefer .webp for performance)
    const novelDir = path.join('src/content/novels', slug);
    const coverPath = fs.existsSync(path.join(novelDir, 'cover.webp')) ? 'cover.webp' :
                  fs.existsSync(path.join(novelDir, 'cover.png')) ? 'cover.png' :
                  fs.existsSync(path.join(novelDir, 'cover.jpg')) ? 'cover.jpg' : null;

    return {
      slug,
      title: n.data.title,
      author: n.data.author || 'AI 生成',
      categories: n.data.categories || ['其他'],
      tags: n.data.tags || [],
      chapters: n.data.totalChapters || 0,
      status: n.data.status || '連載中',
      cover: coverPath ? config.path('/content/novels/' + slug + '/' + coverPath) : null
    };
  });

const categorySlugs = getAllCategorySlugs();
const categories = [
  { name: '全部', slug: 'all', icon: '📚' },
  ...categorySlugs.map(slug => ({
    name: categoryConfig[slug].name,
    slug,
    icon: categoryConfig[slug].icon
  }))
];

// Get URL params for filtering
const searchQuery = Astro.url.searchParams.get('q') || '';
const activeCategory = Astro.url.searchParams.get('category') || 'all';
const activeStatus = Astro.url.searchParams.get('status') || 'all';

// Reading status filter options
const statusFilters = [
  { name: '全部', slug: 'all', icon: '📚' },
  { name: '阅读中', slug: 'reading', icon: '📖' },
  { name: '已完成', slug: 'completed', icon: '✅' },
  { name: '待阅读', slug: 'later', icon: '⭐' }
];
---

<BaseLayout title="书阁 - 小说阁" activeTab="library">
  <!-- Visual Categories - Above the Fold -->
  <VisualCategory />
  
  <!-- Search Header -->
  <div class="search-header">
    <form method="get" action={config.path('/library')} class="search-form">
      <div class="search-form-wrap">
        <input
          type="text"
          name="q"
          value={searchQuery}
          placeholder="搜索小说、作者..."
          class="search-input"
          id="searchInput"
          autocomplete="off"
        >
        <div class="search-suggestions" id="searchSuggestions">
          <div class="search-suggestions-header">
            <span>最近搜尋</span>
            <span class="search-suggestions-clear" id="clearSearchHistory">清除</span>
          </div>
          <div id="searchSuggestionsList"></div>
        </div>
      </div>
      <input type="hidden" name="category" value={activeCategory} id="categoryInput">
      <input type="hidden" name="status" value={activeStatus} id="statusInput">
      <button type="submit" class="search-btn">搜索</button>
    </form>
  </div>

  <!-- Hot Keywords -->
  <div class="hot-keywords">
    <span class="hot-keywords-label">熱門關鍵詞</span>
    <div class="hot-keywords-list">
      <button class="hot-keyword-btn" data-keyword="禪意">禪意</button>
      <button class="hot-keyword-btn" data-keyword="美食">美食</button>
      <button class="hot-keyword-btn" data-keyword="系統">系統</button>
      <button class="hot-keyword-btn" data-keyword="都市">都市</button>
      <button class="hot-keyword-btn" data-keyword="奇幻">奇幻</button>
      <button class="hot-keyword-btn" data-keyword="成長">成長</button>
    </div>
  </div>

  <!-- Tag Filter -->
  <div class="tag-filter" id="tagFilter">
    <div class="tag-filter-label">標籤篩選</div>
    <div class="tag-filter-tags">
      <button class="tag-filter-btn active" data-tag="all">全部</button>
      <button class="tag-filter-btn" data-tag="禪意">禪意</button>
      <button class="tag-filter-btn" data-tag="美食">美食</button>
      <button class="tag-filter-btn" data-tag="素食">素食</button>
      <button class="tag-filter-btn" data-tag="成長">成長</button>
      <button class="tag-filter-btn" data-tag="奇幻">奇幻</button>
      <button class="tag-filter-btn" data-tag="系統">系統</button>
      <button class="tag-filter-btn" data-tag="都市">都市</button>
      <button class="tag-filter-btn" data-tag="人生">人生</button>
    </div>
  </div>

  <!-- Status Tabs (for reading progress filtering) -->
  <div class="status-tabs">
    {statusFilters.map((status) => (
      <button 
        class={`status-tab ${activeStatus === status.slug ? 'active' : ''}`}
        data-status={status.slug}
      >
        <span class="cat-icon">{status.icon}</span>
        <span class="cat-name">{status.name}</span>
      </button>
    ))}
  </div>

  <!-- Category Tabs -->
  <div class="category-tabs">
    {categories.map((cat) => (
      <button 
        class={`category-tab ${activeCategory === cat.slug ? 'active' : ''}`}
        data-category={cat.slug}
      >
        <span class="cat-icon">{cat.icon}</span>
        <span class="cat-name">{cat.name}</span>
      </button>
    ))}
  </div>

  <!-- Results Info -->
  <div class="results-info">
    <span id="resultsCount">{novels.length}</span> 本書籍
    {searchQuery && <span class="search-term">「{searchQuery}」</span>}
  </div>

  <!-- Book Grid -->
  <div class="book-grid" id="bookGrid">
    {novels.map((novel) => (
      <a href={config.path('/book/' + novel.slug)} class="book-card" data-categories={JSON.stringify(novel.categories)} data-tags={JSON.stringify(novel.tags)} data-title={novel.title.toLowerCase()} data-author={novel.author.toLowerCase()} data-slug={novel.slug} data-total-chapters={novel.chapters}>
        <div class="book-cover">
          {novel.cover ? (
            <DualImage src={novel.cover} alt={`${novel.title}封面`} />
          ) : (
            <div class="css-book-cover" style="width: 100%; height: 100%;" role="img" aria-label={`${novel.title}封面`}>
              <div class="cover-content">
                <span class="cover-title">{novel.title}</span>
              </div>
            </div>
          )}
          <span class={`status-badge ${novel.status === '已完結' ? 'status-done' : 'status-ongoing'}`}>
            {novel.status}
          </span>
          </span>
          <!-- Progress indicator (filled by JS) -->
          <div class="book-progress-wrap">
            <div class="book-progress-fill"></div>
          </div>
        </div>
        <div class="book-info">
          <h3>{novel.title}</h3>
          <p>{novel.genre}</p>
          <p class="chapter-num">{novel.chapters} 章</p>
          {novel.tags && novel.tags.length > 0 && (
            <div class="book-tags">
              {novel.tags.slice(0, 3).map((tag) => (
                <span class="book-tag">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>

  <!-- No Results Message -->
  <div class="no-results" id="noResults" style="display: none;">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.35-4.35"></path>
    </svg>
    <p>未找到相關書籍</p>
    <button class="btn-reset" onclick="resetFilters()">清除篩選</button>
  </div>
</BaseLayout>

<style>
  /* Search Header */
  .search-header {
    padding: var(--spacing-4);
    background: var(--bg-base);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .search-form {
    display: flex;
    gap: var(--spacing-3);
    align-items: center;
  }

  .search-input {
    flex: 1;
    padding: var(--spacing-3) var(--spacing-4);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    background: var(--bg-outer);
    transition: all var(--t-normal);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(207, 185, 151, 0.15);
  }

  .search-btn {
    padding: var(--spacing-3) var(--spacing-5);
    background: var(--accent);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-lg);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--t-normal);
  }

  .search-btn:hover {
    background: var(--accent-hover);
  }

  /* Hot Keywords */
  .hot-keywords {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-bg-base);
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    flex-wrap: wrap;
  }

  .hot-keywords-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .hot-keywords-list {
    display: flex;
    gap: var(--spacing-2);
    flex-wrap: wrap;
  }

  .hot-keyword-btn {
    font-size: var(--text-xs);
    padding: 2px 8px;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .hot-keyword-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Tag Filter */
  .tag-filter {
    padding: var(--spacing-3) var(--spacing-4);
    background: var(--color-bg-base);
    border-bottom: 1px solid var(--color-border-light);
  }

  .tag-filter-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--spacing-2);
  }

  .tag-filter-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .tag-filter-btn {
    padding: var(--spacing-1) var(--spacing-3);
    font-size: var(--text-xs);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-full);
    background: var(--color-bg-card);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .tag-filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .tag-filter-btn.active {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  /* Book Tags */
  .book-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: var(--spacing-1);
  }

  .book-tag {
    font-size: 10px;
    padding: 2px 6px;
    background: var(--color-bg-hover);
    color: var(--text-muted);
    border-radius: var(--radius-sm);
  }

  /* Status Tabs */
  .status-tabs {
    display: flex;
    gap: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-4);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    background: var(--bg-base);
    border-bottom: 1px solid var(--color-border-light);
  }

  .status-tabs::-webkit-scrollbar {
    display: none;
  }

  .status-tab {
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
    padding: var(--spacing-1) var(--spacing-3);
    background: var(--bg-outer);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--text-muted);
    cursor: pointer;
    white-space: nowrap;
  }

  .status-tab.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .status-tab .cat-icon {
    font-size: 12px;
  }

  .status-tab .cat-name {
    font-weight: 500;
  }

  /* Category Tabs */
  .category-tabs {
    display: flex;
    gap: var(--spacing-2);
    padding: var(--spacing-3) var(--spacing-4);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    background: var(--bg-base);
    border-bottom: 1px solid var(--color-border-light);
  }

  .category-tabs::-webkit-scrollbar {
    display: none;
  }

  .category-tab {
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
    padding: var(--spacing-2) var(--spacing-3);
    background: var(--bg-outer);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--t-normal);
    white-space: nowrap;
    min-height: 40px;
  }

  .category-tab:active {
    transform: scale(0.98);
  }

  .category-tab.active {
    background: var(--accent);
    color: var(--color-white);
    border-color: var(--accent);
  }

  .category-tab .cat-icon {
    font-size: var(--text-base);
  }

  /* Results Info */
  .results-info {
    padding: var(--spacing-3) var(--spacing-4);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .search-term {
    color: var(--accent);
    font-weight: var(--font-medium);
  }

  /* Book Grid - Bento Style */
  .book-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--bento-gap);
    padding: var(--spacing-4);
    padding-bottom: var(--spacing-8);
  }

  @media (min-width: 640px) {
    .book-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .book-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--bento-gap-lg);
      padding: var(--spacing-6);
      max-width: 1100px;
      margin: 0 auto;
    }
  }

  .book-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: var(--bento-transition);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    overflow: hidden;
  }

  .book-card:active {
    transform: scale(0.98);
  }

  .book-card.hidden {
    display: none;
  }

  @media (hover: hover) {
    .book-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--bento-shadow-hover);
    }
  }

  .book-cover {
    aspect-ratio: 3/4;
    position: relative;
    margin-bottom: 0;
    border-radius: 0;
    overflow: hidden;
  }

  /* Book cover uses shared CSS from ../styles/book-cover.css */

  .css-book-cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-300);
    border-radius: 0;
    overflow: hidden;
    font-family: var(--font-serif);
    box-shadow: var(--bento-shadow);
  }

  .css-book-cover::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: rgba(0, 0, 0, 0.15);
    z-index: 1;
  }

  .cover-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-2);
    color: var(--color-white);
  }

  .cover-title {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-white);
    line-height: var(--line-height-snug);
  }

  .status-badge {
    position: absolute;
    top: var(--spacing-2);
    right: var(--spacing-2);
    padding: var(--spacing-1) var(--spacing-2);
    min-height: 28px;
    min-width: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: var(--font-medium);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    z-index: 2;
  }

  .status-badge.status-ongoing {
    background: var(--accent);
  }

  .status-badge.status-done {
    background: var(--color-success);
  }

  .book-info {
    padding: var(--spacing-3);
    background: var(--color-bg-card);
  }

  /* Reading Progress on Card */
  .book-progress-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: rgba(0, 0, 0, 0.3);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .book-card[data-progress] .book-progress-wrap {
    opacity: 1;
  }

  .book-progress-fill {
    height: 100%;
    background: var(--color-accent);
    width: 0%;
    transition: width 0.3s ease;
  }

  .book-card[data-progress] {
    position: relative;
  }

  .book-info h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: var(--spacing-1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .book-info p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chapter-num {
    color: var(--color-accent) !important;
    font-weight: var(--font-medium);
    margin-top: var(--spacing-1);
  }

  /* No Results */
  .no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-12);
    color: var(--text-muted);
    text-align: center;
  }

  .no-results svg {
    margin-bottom: var(--spacing-3);
    opacity: 0.5;
  }

  .no-results p {
    font-size: var(--text-base);
    margin-bottom: var(--spacing-4);
  }

  .btn-reset {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--accent);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    cursor: pointer;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .book-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: var(--spacing-4);
      padding: var(--spacing-6);
    }

    .search-header,
    .category-tabs,
    .results-info {
      padding: var(--spacing-4) var(--spacing-6);
    }
  }

  @media (min-width: 1024px) {
    .book-grid {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: var(--spacing-5);
      padding: var(--spacing-6) var(--spacing-8);
      max-width: 1100px;
      margin: 0 auto;
    }

    .search-form {
      max-width: 600px;
      margin: 0 auto;
    }
  }

  /* Search Suggestions Dropdown */
  .search-suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg-base);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 100;
    max-height: 300px;
    overflow-y: auto;
    display: none;
  }

  .search-suggestions.active {
    display: block;
  }

  .search-suggestions-header {
    padding: var(--spacing-2) var(--spacing-4);
    font-size: var(--text-xs);
    color: var(--text-muted);
    border-bottom: 1px solid var(--color-border-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .search-suggestions-clear {
    cursor: pointer;
    color: var(--accent);
    font-size: var(--text-xs);
  }

  .search-suggestions-clear:hover {
    text-decoration: underline;
  }

  .search-suggestion-item {
    padding: var(--spacing-3) var(--spacing-4);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    transition: background var(--t-fast);
  }

  .search-suggestion-item:hover {
    background: var(--bg-hover);
  }

  .search-suggestion-item svg {
    width: 14px;
    height: 14px;
    color: var(--text-muted);
  }

  .search-suggestion-item span {
    font-size: var(--text-sm);
    color: var(--text-dark);
  }

  .search-form-wrap {
    position: relative;
    flex: 1;
  }
</style>

<script>
  // Initialize reading progress on book cards
  function initCardProgress() {
    try {
      const progressData = localStorage.getItem('reading_progress');
      const progress = progressData ? JSON.parse(progressData) : {};
      
      bookCards.forEach((card) => {
        const el = card as HTMLElement;
        const slug = el.dataset.slug;
        const totalChapters = parseInt(el.dataset.totalChapters || '0');
        
        if (slug && progress[slug] && totalChapters > 0) {
          const currentChapter = progress[slug].currentChapter || progress[slug].chapter || 1;
          const percent = Math.round((currentChapter / totalChapters) * 100);
          el.dataset.progress = percent.toString();
          const fill = el.querySelector('.book-progress-fill') as HTMLElement;
          if (fill) {
            fill.style.width = percent + '%';
          }
        }
      });
    } catch (e) {
      console.warn('Failed to init card progress:', e);
    }
  }

  // Client-side filtering
  const categoryTabs = document.querySelectorAll<HTMLElement>('.category-tab');
  const statusTabs = document.querySelectorAll<HTMLElement>('.status-tab');
  const bookCards = document.querySelectorAll<HTMLElement>('.book-card');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const categoryInput = document.getElementById('categoryInput') as HTMLInputElement | null;
  const statusInput = document.getElementById('statusInput') as HTMLInputElement | null;
  const resultsCount = document.getElementById('resultsCount');
  const noResults = document.getElementById('noResults');
  const searchTermSpan = document.querySelector<HTMLElement>('.search-term');
  const searchSuggestions = document.getElementById('searchSuggestions');
  const searchSuggestionsList = document.getElementById('searchSuggestionsList');
  const clearSearchHistory = document.getElementById('clearSearchHistory');

  // ========== Search History ==========
  const SEARCH_HISTORY_KEY = 'zen-novel-search-history';
  const MAX_HISTORY = 10;

  function getSearchHistory(): string[] {
    try {
      return JSON.parse(localStorage.getItem(SEARCH_HISTORY_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function saveSearchToHistory(query: string) {
    if (!query.trim()) return;
    try {
      let history = getSearchHistory();
      history = history.filter(h => h !== query);
      history.unshift(query);
      if (history.length > MAX_HISTORY) history = history.slice(0, MAX_HISTORY);
      localStorage.setItem(SEARCH_HISTORY_KEY, JSON.stringify(history));
    } catch {}
  }

  function doClearSearchHistory() {
    try {
      localStorage.removeItem(SEARCH_HISTORY_KEY);
      renderSearchSuggestions();
    } catch {}
  }

  function renderSearchSuggestions() {
    if (!searchSuggestionsList) return;
    const history = getSearchHistory();
    if (history.length === 0) {
      searchSuggestionsList.innerHTML = '<div class="search-suggestion-item"><span style="color: var(--text-muted); font-size: var(--text-sm);">尚無搜尋紀錄</span></div>';
      return;
    }
    searchSuggestionsList.innerHTML = history.map(q => `
      <div class="search-suggestion-item" data-query="${q}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        <span>${q}</span>
      </div>
    `).join('');
  }

  function showSearchSuggestions() {
    renderSearchSuggestions();
    searchSuggestions?.classList.add('active');
  }

  function hideSearchSuggestions() {
    setTimeout(() => {
      searchSuggestions?.classList.remove('active');
    }, 200);
  }

  // Show suggestions on focus
  searchInput?.addEventListener('focus', () => {
    const history = getSearchHistory();
    if (history.length > 0) showSearchSuggestions();
  });

  // Hide suggestions on blur
  searchInput?.addEventListener('blur', hideSearchSuggestions);

  // Click on suggestion
  searchSuggestionsList?.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.search-suggestion-item') as HTMLElement;
    if (item && searchInput) {
      const query = item.dataset.query;
      if (query) {
        searchInput.value = query;
        (searchInput.closest('form') as HTMLFormElement).submit();
      }
    }
  });

  // Clear history
  clearSearchHistory?.addEventListener('click', (e) => {
    e.stopPropagation();
    doClearSearchHistory();
  });

  // Save search on submit
  const searchForm = document.querySelector('.search-form') as HTMLFormElement;
  searchForm?.addEventListener('submit', () => {
    if (searchInput?.value) {
      saveSearchToHistory(searchInput.value);
    }
  });

  // Hot keywords click handlers
  const hotKeywordBtns = document.querySelectorAll<HTMLElement>('.hot-keyword-btn');
  hotKeywordBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const keyword = (btn as HTMLElement).dataset.keyword;
      if (keyword && searchInput) {
        searchInput.value = keyword;
        saveSearchToHistory(keyword);
        filterBooks();
      }
    });
  });

  // Initialize progress on load
  initCardProgress();

  // Status tab click handlers
  statusTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const status = (tab as HTMLElement).dataset.status || 'all';
      if (statusInput) statusInput.value = status;
      
      // Update active state
      statusTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      filterBooks();
    });
  });

  // Tag filter click handlers
  const tagFilterBtns = document.querySelectorAll<HTMLElement>('.tag-filter-btn');
  tagFilterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag || 'all';
      (window as any).__activeTag = tag;

      // Update active state
      tagFilterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      filterBooks();
    });
  });

  function filterBooks() {
    const searchTerm = (searchInput?.value || '').toLowerCase().trim();
    const activeCategory = categoryInput?.value || 'all';
    const activeStatus = statusInput?.value || 'all';
    const activeTag = (window as any).__activeTag || 'all';

    let visibleCount = 0;

    bookCards.forEach((card) => {
      const el = card as HTMLElement;
      const categoriesStr = el.dataset.categories;
      const categories = categoriesStr ? JSON.parse(categoriesStr) : [];
      const tagsStr = el.dataset.tags;
      const tags = tagsStr ? JSON.parse(tagsStr) : [];
      const title = (el.dataset.title || '').toLowerCase();
      const author = (el.dataset.author || '').toLowerCase();
      const slug = el.dataset.slug;
      const totalChapters = parseInt(el.dataset.totalChapters || '0');

      const matchesSearch = !searchTerm ||
        title.includes(searchTerm) ||
        author.includes(searchTerm) ||
        tags.some((t: string) => t.toLowerCase().includes(searchTerm));

      const matchesCategory = activeCategory === 'all' ||
        categories.includes(activeCategory);

      // Tag filtering
      const matchesTag = activeTag === 'all' || tags.includes(activeTag);
      
      // Status filtering based on reading progress
      let matchesStatus = true;
      if (activeStatus !== 'all') {
        try {
          const progressData = localStorage.getItem('reading_progress');
          const progress = progressData ? JSON.parse(progressData) : {};
          const currentProgress = progress[slug || ''];
          
          if (activeStatus === 'reading') {
            // Has progress but not complete
            matchesStatus = currentProgress && totalChapters > 0 && 
              (currentProgress.currentChapter || currentProgress.chapter || 1) < totalChapters;
          } else if (activeStatus === 'completed') {
            // Finished all chapters
            matchesStatus = currentProgress && totalChapters > 0 && 
              (currentProgress.currentChapter || currentProgress.chapter || 0) >= totalChapters;
          } else if (activeStatus === 'later') {
            // In favorites but no reading progress
            const favData = localStorage.getItem('favorites');
            const favorites = favData ? JSON.parse(favData) : [];
            const isFav = favorites.some((f: any) => f.id === slug);
            matchesStatus = isFav && !currentProgress;
          }
        } catch (e) {
          matchesStatus = true;
        }
      }
      
      if (matchesSearch && matchesCategory && matchesStatus && matchesTag) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });
    
    // Update results count
    if (resultsCount) {
      resultsCount.textContent = String(visibleCount);
    }
    
    // Show/hide no results
    if (noResults) {
      noResults.style.display = visibleCount === 0 ? 'flex' : 'none';
    }
   
    // Update search term display
    if (searchTermSpan) {
      searchTermSpan.textContent = searchTerm ? `「${searchTerm}」` : '';
    }
  }

  // Category tab click handlers
  categoryTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.category || 'all';
      
      // Update active state
      categoryTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      
      // Update hidden input
      if (categoryInput) {
        categoryInput.value = cat;
      }
      
      // Filter books
      filterBooks();
      
      // Update URL without reload
      const url = new URL(window.location.href);
      url.searchParams.set('category', cat);
      window.history.pushState({}, '', url);
    });
  });

  // Reset filters function (global for onclick)
  function resetFilters() {
    if (searchInput) searchInput.value = '';
    if (categoryInput) categoryInput.value = 'all';
    
    categoryTabs.forEach(t => t.classList.remove('active'));
    categoryTabs[0].classList.add('active');
    
    const url = new URL(window.location.href);
    url.searchParams.delete('q');
    url.searchParams.delete('category');
    window.history.pushState({}, '', url);
    
    filterBooks();
  }
  
  // Make resetFilters available globally for onclick handler
  // @ts-ignore - inline onclick requires global function
  (window as any).resetFilters = resetFilters;

  // Initial filter on page load
  filterBooks();

  // Handle browser back/forward
  window.addEventListener('popstate', () => {
    const url = new URL(window.location.href);
    const q = url.searchParams.get('q') || '';
    const category = url.searchParams.get('category') || 'all';
    
    if (searchInput) searchInput.value = q;
    if (categoryInput) categoryInput.value = category;
    
    categoryTabs.forEach(t => {
      const cat = t.dataset.category;
      t.classList.toggle('active', cat === category);
    });
    
    filterBooks();
  });
</script>