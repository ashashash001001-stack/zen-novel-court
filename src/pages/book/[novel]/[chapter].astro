---
import ReaderLayout from '../../../layouts/ReaderLayout.astro';
import { config } from '../../../config';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const novels = await getCollection('novels');
  
  const paths = [];
  
  for (const novel of novels) {
    // Skip non-meta entries
    if (!novel.id.endsWith('/meta')) continue;
    
    const slug = novel.id.replace('/meta', '');
    const data = novel.data;
    const chapters = data.totalChapters || data.chapters || 0;
    
    for (let i = 1; i <= chapters; i++) {
      const chapterPath = `../../../content/novels/${slug}/chapters/${i}.md`;
      const chapterModule = import.meta.glob('../../../content/novels/*/chapters/*.md', { eager: true })[chapterPath] as any;
      
      paths.push({
        params: { novel: slug, chapter: String(i) },
        props: { 
          novel: { slug, ...data }, 
          chapter: i,
          chapterTitle: chapterModule?.frontmatter?.title || `第 ${i} 章`,
          chapterPart: chapterModule?.frontmatter?.part || '',
          ChapterContent: chapterModule?.default
        }
      });
    }
  }
  
  return paths;
}

const { novel, chapter: chapterNum, chapterTitle, chapterPart, ChapterContent } = Astro.props;
// Get config.base for links - safe access
const basePath = (config as { base?: string }).base || '';
const totalChapters = novel.totalChapters || novel.chapters || 0;
const chaptersList = Array.from({ length: totalChapters }, (_, i) => i + 1);
const hasPrev = chapterNum > 1;
const hasNext = chapterNum < chaptersList.length;

// Reading statistics
const progressPercent = Math.round((chapterNum / totalChapters) * 100);

// We'll calculate word count in client-side JS
// Passing placeholder that will be replaced at runtime
const wordCountPlaceholder = '0';
const readingTimePlaceholder = '0';
---

<ReaderLayout title={`${novel.title} - ${chapterTitle}`}>
  <div class="reader-page" data-has-next={hasNext ? 'true' : 'false'} data-total-chapters={totalChapters}>
    <!-- Reading Progress Bar -->
    <div class="reader-progress" id="readerProgress">
      <div class="reader-progress-bar" id="readerProgressBar"></div>
    </div>

    <!-- Top Bar -->
    <header class="reader-topbar" id="readerTopbar">
      <div class="reader-topbar-inner">
        <a href={config.path('/book/' + novel.slug)} class="reader-topbar-back btn-press">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-7-7 7-7"/>
          </svg>
        </a>
        <span class="reader-topbar-title">{novel.title}</span>
        <span class="reader-topbar-breadcrumb">
          <a href={config.path('/book/' + novel.slug)}>{novel.title}</a>
          <span> › </span>
          <span>{chapterTitle}</span>
        </span>
        <!-- Reading Stats -->
        <div class="reader-stats" id="readerStats">
          <span class="stat-item" id="statWordCount">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
            </svg>
            <span class="stat-value" id="wordCountValue">--</span>
            <span class="stat-unit">字</span>
          </span>
          <span class="stat-divider">·</span>
          <span class="stat-item" id="statReadTime">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span class="stat-value" id="readTimeValue">--</span>
            <span class="stat-unit">分鐘</span>
          </span>
          <span class="stat-divider">·</span>
          <span class="stat-item" id="statProgress">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            <span class="stat-value" id="progressValue">{chapterNum}/{totalChapters}</span>
            <span class="stat-unit">({progressPercent}%)</span>
          </span>
        </div>
      </div>
    </header>

    <!-- Reading Content -->
    <main class="reader-immersive" id="readerEl">
      <article class="reader-content" id="readerContent">
        <h1 class="chapter-heading">{chapterPart && <span class="chapter-part">{chapterPart}</span>}{chapterTitle}</h1>
        {ChapterContent && <ChapterContent />}
      </article>
    </main>

    <!-- Bottom Bar -->
    <footer class="reader-bottombar" id="readerBottombar">
      <div class="reader-bottombar-inner">
        <button class="nav-btn btn-press" id="prevChapterBtn" disabled={!hasPrev}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-7-7 7-7"/>
          </svg>
          <span class="nav-label">上一章</span>
        </button>
        
        <div class="reader-bottombar-tools">
          <button class="tool-btn btn-press" id="toolBtnToc" aria-label="目錄">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
            </svg>
            <span>目錄</span>
          </button>
          <button class="tool-btn btn-press" id="toolBtnSettings" aria-label="设置">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 12h.01M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
            </svg>
            <span>设置</span>
          </button>
          <button class="tool-btn btn-press" id="toolBtnMore" aria-label="更多">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span>更多</span>
          </button>
          <button class="tool-btn btn-press" id="toolBtnTts" aria-label="朗讀">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M12 12h.01"/>
            </svg>
            <span>朗讀</span>
          </button>
          <button class="tool-btn btn-press" id="toolBtnBookmark" aria-label="書籤">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" id="bookmarkIcon">
              <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
            <span>書籤</span>
          </button>
        </div>
        
        <button class="nav-btn btn-press" id="nextChapterBtn" disabled={!hasNext}>
          <span class="nav-label">下一章</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </footer>

    <!-- TOC Sheet -->
    <div class="sheet-overlay" id="tocSheet">
      <div class="sheet-content" onclick="event.stopPropagation()">
        <div class="sheet-handle"></div>
        <div class="sheet-header">
          <h3>章節目錄</h3>
          <button class="btn-press sheet-close" onclick="closeSheet('tocSheet')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="sheet-body">
          {chaptersList.map((num) => (
            <a href={config.path('/book/' + novel.slug + '/' + num)} class={`toc-item btn-press ${num === chapterNum ? 'active' : ''}`}>
              <span>第 {num} 章</span>
              {num === chapterNum && <span class="toc-current">進行中</span>}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Settings Sheet -->
    <div class="sheet-overlay" id="settingsSheet">
      <div class="sheet-content" onclick="event.stopPropagation()">
        <div class="sheet-handle"></div>
        <div class="sheet-header">
          <h3>阅读设置</h3>
          <button class="btn-press sheet-close" onclick="closeSheet('settingsSheet')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="sheet-body">
          <div class="setting-group">
            <div class="setting-label">外觀模式</div>
            <div class="setting-row theme-options">
              <button class="setting-btn theme-btn" id="themeAuto" onclick="setTheme('auto')" title="自動（跟隨系統）">🌐</button>
              <button class="setting-btn theme-btn" id="themeLight" onclick="setTheme('light')" style="background:#FDFBF7">白底</button>
              <button class="setting-btn theme-btn" id="themeSepia" onclick="setTheme('sepia')" style="background:#F5F0E8">護眼</button>
              <button class="setting-btn theme-btn" id="themeGreen" onclick="setTheme('green')" style="background:#E8F0E8">綠色</button>
              <button class="setting-btn theme-btn" id="themeNight" onclick="setTheme('night')" style="background:#1E1E1C;color:#fff">夜間</button>
            </div>
          </div>
          <div class="setting-group">
            <div class="setting-label">字体大小 <span id="fontSizeVal">18px</span></div>
            <div class="setting-range">
              <span class="range-label">A</span>
              <input type="range" min="14" max="28" value="18" id="fontSizeRange" oninput="setFontSize(this.value)">
              <span class="range-label large">A</span>
            </div>
          </div>
          <div class="setting-group">
            <div class="setting-label">字体</div>
            <div class="setting-row font-options">
              <button class="setting-btn" id="fontSans" onclick="setFont('sans')">思源黑體</button>
              <button class="setting-btn" id="fontSerif" onclick="setFont('serif')">思源宋體</button>
              <button class="setting-btn" id="fontSystem" onclick="setFont('system')">系統預設</button>
              <button class="setting-btn" id="fontPingFang" onclick="setFont('pingfang')">蘋方體</button>
              <button class="setting-btn" id="fontJhengHei" onclick="setFont('jhenghei')">微軟正黑</button>
            </div>
          </div>
          <div class="setting-group">
            <div class="setting-label">行距 <span id="lineHeightVal">1.7</span></div>
            <div class="setting-range">
              <span class="range-label">緊</span>
              <input type="range" min="1.4" max="2.2" step="0.1" value="1.7" id="lineHeightRange" oninput="setLineHeight(this.value)">
              <span class="range-label large">鬆</span>
            </div>
          </div>
          <div class="setting-group">
            <div class="setting-label">段落間距 <span id="paraSpacingVal">1.5em</span></div>
            <div class="setting-range">
              <span class="range-label">小</span>
              <input type="range" min="0" max="2.5" step="0.25" value="1.5" id="paraSpacingRange" oninput="setParaSpacing(this.value)">
              <span class="range-label large">大</span>
            </div>
          </div>
          <div class="setting-group">
            <div class="setting-label">對齊方式</div>
            <div class="setting-row">
              <button class="setting-btn" id="alignLeft" onclick="setTextAlign('left')">靠左</button>
              <button class="setting-btn" id="alignJustify" onclick="setTextAlign('justify')">分散</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TTS Sheet -->
    <div class="sheet-overlay" id="ttsSheet">
      <div class="sheet-content" onclick="event.stopPropagation()">
        <div class="sheet-handle"></div>
        <div class="sheet-header">
          <h3>发声朗读</h3>
          <button class="btn-press sheet-close" onclick="closeSheet('ttsSheet')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="sheet-body tts-body">
          <button class="tts-play-btn btn-press" id="ttsPlayBtn">
            <svg id="ttsPlayIcon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="ttsPauseIcon" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="hidden">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>
          <div class="tts-progress-wrap">
            <input type="range" min="0" max="100" value="0" step="1" id="ttsRange" class="tts-range-slider" oninput="seekTTS(this.value)">
            <div class="tts-progress-label">
              <span id="ttsCurrentPara">0</span> / <span id="ttsTotalPara">0</span>
            </div>
          </div>
          <div class="tts-control">
            <div class="tts-label">
              <span>語速</span>
              <span id="ttsRateVal">1.0x</span>
            </div>
            <input type="range" min="0.5" max="2" step="0.1" value="1" id="ttsRate" oninput="setTTSRate(this.value)">
            <div class="tts-label">
              <span>音高</span>
              <span id="ttsPitchVal">1.0</span>
            </div>
            <input type="range" min="0.5" max="2" step="0.1" value="1" id="ttsPitch" oninput="setTTSPitch(this.value)">
          </div>
        </div>
      </div>
    </div>

    <!-- More Navigation Sheet -->
    <div class="sheet-overlay" id="moreSheet">
      <div class="sheet-content" onclick="event.stopPropagation()">
        <div class="sheet-handle"></div>
        <div class="sheet-header">
          <h3>導航</h3>
          <button class="btn-press sheet-close" onclick="closeSheet('moreSheet')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="sheet-body">
          <a href={config.path('/')} class="nav-item btn-press">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <span>首页</span>
          </a>
          <a href={config.path('/library')} class="nav-item btn-press">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
            <span>书库</span>
          </a>
          <a href={config.path('/my')} class="nav-item btn-press">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>我的</span>
          </a>
          <a href={config.path('/book/' + novel.slug)} class="nav-item btn-press">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              <line x1="12" y1="6" x2="12" y2="12"/>
            </svg>
            <span>书籍详情页</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</ReaderLayout>

<style>
  /* Reader Page Layout */
  .reader-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .reader-immersive {
    background: var(--bg-reading);
    color: var(--text-dark);
    min-height: 100vh;
    width: 100%;
    padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
    position: relative;
    transition: background var(--t-slow), color var(--t-slow);
  }

  /* Progress Bar */
  .reader-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-border-light);
    z-index: 101;
  }

  .reader-progress-bar {
    height: 100%;
    background: var(--accent);
    transition: width 0.3s ease;
    width: 0%;
  }

  /* Top Bar */
  .reader-topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    /* Solid background fallback + gradient overlay for consistent visibility */
    background: var(--bg-base);
    background-image: linear-gradient(to bottom, var(--bg-base) 60%, transparent 100%);
    padding: var(--spacing-2) var(--spacing-3);
    padding-top: calc(var(--spacing-2) + env(safe-area-inset-top, 8px));
    transition: transform var(--t-normal), background var(--t-slow);
  }

  .reader-topbar.hidden {
    transform: translateY(-100%);
  }

  .reader-topbar-inner {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    max-width: 900px;
    margin: 0 auto;
    min-height: 44px;
  }

  .reader-topbar-back {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.6);
    color: var(--text-dark);
    flex-shrink: 0;
    transition: all var(--t-normal);
    text-decoration: none;
    touch-action: manipulation;
  }

  .reader-topbar-back:active {
    transform: scale(0.98);
  }

  .reader-topbar-title {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
    font-family: var(--font-sans);
  }

  .reader-topbar-breadcrumb {
    display: none;
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reader-topbar-breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
  }

  /* Reading Stats in Top Bar */
  .reader-stats {
    display: none;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-left: auto;
    padding-right: var(--space-2);
  }

  .reader-stats .stat-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .reader-stats .stat-value {
    font-weight: var(--font-medium);
    color: var(--text-dark);
  }

  .reader-stats .stat-unit {
    color: var(--text-muted);
  }

  .reader-stats .stat-divider {
    opacity: 0.4;
    margin: 0 2px;
  }

  .reader-stats svg {
    opacity: 0.6;
  }

  /* Bottom Bar */
  .reader-bottombar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    /* Solid background fallback + gradient overlay for consistent visibility */
    background: var(--bg-base);
    background-image: linear-gradient(to top, var(--bg-base) 60%, transparent 100%);
    padding: var(--spacing-2) var(--spacing-3);
    padding-bottom: calc(var(--spacing-3) + env(safe-area-inset-bottom, 8px));
    transition: transform var(--t-normal), background var(--t-slow);
  }

  .reader-bottombar.hidden {
    transform: translateY(100%);
  }

  .reader-bottombar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-2);
    max-width: 900px;
    margin: 0 auto;
  }

  .reader-bottombar-tools {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  /* Navigation Buttons */
  .nav-btn {
    display: flex;
    align-items: center;
    gap: var(--spacing-1);
    padding: var(--spacing-2);
    min-width: 40px;
    min-height: 40px;
    justify-content: center;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    background: var(--bg-base);
    color: var(--text-dark);
    font-size: 0;
    font-weight: var(--font-medium);
    text-decoration: none;
    transition: all var(--t-normal);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .nav-btn svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .nav-btn .nav-label {
    display: none;
  }

  .nav-btn:active {
    transform: scale(0.98);
  }

  .nav-btn:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  /* Tool Buttons */
  .tool-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    background: var(--bg-base);
    color: var(--text-dark);
    font-size: 0;
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--t-normal);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tool-btn svg {
    width: 18px;
    height: 18px;
  }

  .tool-btn span {
    display: none;
  }

  .tool-btn:active {
    transform: scale(0.98);
  }

  .tool-btn.active {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Reader Content */
  .reader-content {
    padding: var(--space-8) var(--space-6);
    padding-top: 80px;
    padding-bottom: 160px;
    font-family: var(--font-serif);
    font-size: var(--reader-font-size, var(--text-reading));
    line-height: var(--reader-line-height, var(--line-height-relaxed));
    letter-spacing: var(--reader-letter-spacing, 0.5px);
    max-width: var(--reading-max-width);
    margin: 0 auto;
    text-align: justify;
  }

