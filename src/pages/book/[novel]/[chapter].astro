  }
</style>

<script>
  (window as any).__configBase__ = document.body.dataset.basePath;

  // Reader State
  const state = {
    uiVisible: true,
    ttsPlaying: false,
    ttsUtterance: null as SpeechSynthesisUtterance | null,
    ttsCurrentIdx: 0,
    scrollStartY: 0,
    touchStartX: 0
  };

// Save to Reading History and get novel slug for navigation
   const pathParts = window.location.pathname.split('/').filter(p => p);
   const bookIndex = pathParts.indexOf('book');
   let novelSlug = '';
   let currentChapter = 1;

   // ========== Reading Progress Enhancement ==========
   // Save reading progress (chapter + scroll position)
   function saveReadingProgress() {
     if (!novelSlug) return;
     const progress = {
       bookId: novelSlug,
       chapter: currentChapter,
       scrollY: window.scrollY,
       timestamp: Date.now()
     };
     try {
       localStorage.setItem('reading-progress', JSON.stringify(progress));
     } catch (e) {}
   }

   // Restore reading progress when page loads
   function restoreReadingProgress() {
     try {
       const saved = localStorage.getItem('reading-progress');
       if (saved) {
         const progress = JSON.parse(saved);
         // If same book and chapter, restore scroll position
         if (progress.bookId === novelSlug && progress.chapter === currentChapter && progress.scrollY > 0) {
           // Delay to ensure content is loaded
           setTimeout(() => {
             window.scrollTo(0, progress.scrollY);
           }, 100);
         }
       }
     } catch (e) {}
   }

   // Save progress on scroll (debounced) and before leaving
   // Note: saveReadingProgress already includes scrollY in the progress object
   let saveProgressTimeout: ReturnType<typeof setTimeout>;
   window.addEventListener('scroll', () => {
     clearTimeout(saveProgressTimeout);
     saveProgressTimeout = setTimeout(saveReadingProgress, 1000);
   });
   window.addEventListener('beforeunload', saveReadingProgress);

   // Restore scroll position on page load (uses existing restoreReadingProgress)
   restoreReadingProgress();

   if (bookIndex !== -1) {
     const rawSlug = pathParts[bookIndex + 1] || '';
     novelSlug = decodeURIComponent(rawSlug);
     
     if (pathParts[bookIndex + 2]) {
       currentChapter = parseInt(pathParts[bookIndex + 2], 10) || 1;
     }
     
     if (novelSlug) {
       let history = [];
       try {
         const stored = localStorage.getItem('history');
         history = stored ? JSON.parse(stored) : [];
       } catch (e) {
         history = [];
       }
       
       const entry = { id: novelSlug, chapter: currentChapter, timestamp: Date.now() };
       history = history.filter((h: { id: string }) => h.id !== novelSlug);
       history.unshift(entry);
       if (history.length > 20) history = history.slice(0, 20);
       
       localStorage.setItem('history', JSON.stringify(history));
       console.log('✓ HISTORY SAVED! Total:', history.length);
     }
   }

  // ========== DOM Elements ==========
  const readerProgress = document.getElementById('readerProgress');
  const readerProgressBar = document.getElementById('readerProgressBar');
  const readerTopbar = document.getElementById('readerTopbar');
  const readerBottombar = document.getElementById('readerBottombar');
  const readerEl = document.getElementById('readerEl');
  const readerContent = document.getElementById('readerContent');

  // ========== Progress Bar ==========
  function updateProgress() {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (readerProgressBar) {
      readerProgressBar.style.width = `${progress}%`;
    }
  }

  // ========== UI Visibility Toggle ==========
  let hideTimeout: ReturnType<typeof setTimeout>;

  function showUI() {
    state.uiVisible = true;
    readerTopbar?.classList.remove('hidden');
    readerBottombar?.classList.remove('hidden');
    clearTimeout(hideTimeout);
    hideTimeout = setTimeout(() => {
      if (state.uiVisible && !document.querySelector('.sheet-overlay.active')) {
        hideUI();
      }
    }, 3000);
  }

  function hideUI() {
    state.uiVisible = false;
    readerTopbar?.classList.add('hidden');
    readerBottombar?.classList.add('hidden');
  }

  function toggleUI() {
    if (state.uiVisible) {
      hideUI();
    } else {
      showUI();
    }
  }

  // Tap content to toggle UI
  readerEl?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.tool-btn') || target.closest('.nav-btn') || target.closest('.sheet-overlay')) {
      return;
    }
    toggleUI();
  });

  // ========== Scroll Handling ==========
  let lastScrollY = 0;

  window.addEventListener('scroll', () => {
    updateProgress();
    
    const currentScrollY = window.scrollY;
    if (currentScrollY > lastScrollY && currentScrollY > 50) {
      // Scrolling down - hide UI
      if (state.uiVisible) {
        hideUI();
      }
    } else if (currentScrollY < lastScrollY) {
      // Scrolling up - show UI
      if (!state.uiVisible && currentScrollY < 100) {
        showUI();
      }
    }
    lastScrollY = currentScrollY;
  });

  // ========== Sheet Functions ==========
  (window as any).openSheet = function(id: string) {
    document.getElementById(id)?.classList.add('active');
    showUI();
  };

  (window as any).closeSheet = function(id: string) {
    document.getElementById(id)?.classList.remove('active');
  };

  // Close sheets when clicking overlay
  document.querySelectorAll('.sheet-overlay').forEach(overlay => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        overlay.classList.remove('active');
      }
    });
  });

  // ========== Toolbar Buttons ==========
  const toolBtnToc = document.getElementById('toolBtnToc');
  const toolBtnSettings = document.getElementById('toolBtnSettings');
  const toolBtnMore = document.getElementById('toolBtnMore');
  const toolBtnTts = document.getElementById('toolBtnTts');
  const toolBtnBookmark = document.getElementById('toolBtnBookmark');
  const prevChapterBtn = document.getElementById('prevChapterBtn');
  const nextChapterBtn = document.getElementById('nextChapterBtn');

  toolBtnToc?.addEventListener('click', () => (window as any).openSheet('tocSheet'));
  toolBtnSettings?.addEventListener('click', () => (window as any).openSheet('settingsSheet'));
  toolBtnMore?.addEventListener('click', () => (window as any).openSheet('moreSheet'));
  toolBtnTts?.addEventListener('click', () => {
    initTTS();
    (window as any).openSheet('ttsSheet');
  });

  // ========== Bookmark Functionality ==========
  const BOOKMARKS_KEY = 'zen-novel-bookmarks';

  function getBookmarks(): number[] {
    if (!novelSlug) return [];
    try {
      const all = JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '{}');
      return all[novelSlug] || [];
    } catch {
      return [];
    }
  }

  function toggleBookmark(): number[] {
    if (!novelSlug || !currentChapter) return [];
    try {
      const all = JSON.parse(localStorage.getItem(BOOKMARKS_KEY) || '{}');
      let bookmarks = all[novelSlug] || [];
      const idx = bookmarks.indexOf(currentChapter);
      if (idx > -1) {
        bookmarks.splice(idx, 1);
      } else {
        bookmarks.push(currentChapter);
      }
      all[novelSlug] = bookmarks;
      localStorage.setItem(BOOKMARKS_KEY, JSON.stringify(all));
      updateBookmarkUI();
      return bookmarks;
    } catch {
      return [];
    }
  }

  function updateBookmarkUI() {
    const bookmarks = getBookmarks();
    const isBookmarked = bookmarks.includes(currentChapter);
    const bookmarkIcon = document.getElementById('bookmarkIcon');
    if (bookmarkIcon) {
      bookmarkIcon.setAttribute('fill', isBookmarked ? 'currentColor' : 'none');
    }
    toolBtnBookmark?.classList.toggle('active', isBookmarked);
  }

  toolBtnBookmark?.addEventListener('click', () => {
    toggleBookmark();
  });

  // Initialize bookmark state
  updateBookmarkUI();

// Get base path from window.__configBase__ or extract from URL
let basePath = (window as any).__configBase__ || '/';
if (!basePath || basePath === '/') {
  // Fallback: extract from URL when __configBase__ is not set
  const parts = window.location.pathname.split('/').filter(p => p);
  const idx = parts.indexOf('book');
  basePath = idx > 0 ? '/' + parts.slice(0, idx).join('/') : '';
}

prevChapterBtn?.addEventListener('click', () => {
  const current = parseInt(pathParts[pathParts.length - 1], 10) || 1;
  if (current > 1) window.location.href = `${basePath}/book/${novelSlug}/${current - 1}`;
});

nextChapterBtn?.addEventListener('click', () => {
  const current = parseInt(pathParts[pathParts.length - 1], 10) || 1;
  window.location.href = `${basePath}/book/${novelSlug}/${current + 1}`;
});

  // ========== Touch Swipe Gestures ==========
  document.addEventListener('touchstart', (e) => {
    state.touchStartX = e.touches[0].clientX;
    state.scrollStartY = window.scrollY;
  }, { passive: true });

  document.addEventListener('touchend', (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const deltaX = touchEndX - state.touchStartX;
    const scrollDelta = Math.abs(window.scrollY - state.scrollStartY);
    
    // Only trigger swipe if scroll was minimal
    if (Math.abs(deltaX) > 50 && scrollDelta < 10) {
      if (deltaX > 0 && prevChapterBtn && !prevChapterBtn.hasAttribute('disabled')) {
        // Swipe right - previous chapter
        prevChapterBtn.click();
      } else if (deltaX < 0 && nextChapterBtn && !nextChapterBtn.hasAttribute('disabled')) {
        // Swipe left - next chapter
        nextChapterBtn.click();
      }
    }
  }, { passive: true });

  // ========== Keyboard Navigation ==========
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft' && prevChapterBtn && !prevChapterBtn.hasAttribute('disabled')) {
      prevChapterBtn.click();
    } else if (e.key === 'ArrowRight' && nextChapterBtn && !nextChapterBtn.hasAttribute('disabled')) {
      nextChapterBtn.click();
    } else if (e.key === 'Escape') {
      document.querySelectorAll('.sheet-overlay.active').forEach(sheet => {
        sheet.classList.remove('active');
      });
    }
  });

  // ========== Reading Settings ==========
  function loadSettings() {
    try {
      const theme = localStorage.getItem('dn_theme');

      // Handle "auto" theme - follow system preference
      if (theme === 'auto' || !theme) {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const systemTheme = prefersDark ? 'night' : 'light';
        (window as any).setTheme(systemTheme);
        // Store "auto" preference but apply system theme
        localStorage.setItem('dn_theme', 'auto');
      } else if (theme) {
        (window as any).setTheme(theme);
      }

      const fontSize = localStorage.getItem('dn_fontsize');
      if (fontSize) (window as any).setFontSize(fontSize);

      const font = localStorage.getItem('dn_font');
      if (font) (window as any).setFont(font);

      const lineHeight = localStorage.getItem('dn_lineheight');
      if (lineHeight) (window as any).setLineHeight(lineHeight);

      const paraSpacing = localStorage.getItem('dn_paraspacing');
      if (paraSpacing) (window as any).setParaSpacing(paraSpacing);

      const textAlign = localStorage.getItem('dn_textalign');
      if (textAlign) (window as any).setTextAlign(textAlign);
    } catch (e) {}
  }

  // Listen for system theme changes when in auto mode
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    const theme = localStorage.getItem('dn_theme');
    if (theme === 'auto' || !theme) {
      const newTheme = e.matches ? 'night' : 'light';
      (window as any).setTheme(newTheme);
    }
  });

  (window as any).setTheme = function(t: string) {
    // Handle "auto" theme - apply system preference
    let actualTheme = t;
    if (t === 'auto') {
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      actualTheme = prefersDark ? 'night' : 'light';
    }

    // Set both data-theme (existing) and data-reader-theme (new)
    if (actualTheme === 'light') {
      document.documentElement.removeAttribute('data-theme');
      document.documentElement.removeAttribute('data-reader-theme');
    } else {
      document.documentElement.setAttribute('data-theme', actualTheme);
      document.documentElement.setAttribute('data-reader-theme', actualTheme);
    }
    try {
      // Store 'auto' as preference, but apply actual theme
      localStorage.setItem('dn_theme', t);
      // Also save to new reader-settings format
      localStorage.setItem('zen-novel-reader-prefs', JSON.stringify({ theme: actualTheme }));
    } catch (e) {}

    // Update active state for all theme buttons
    document.getElementById('themeAuto')?.classList.toggle('active', t === 'auto');
    document.getElementById('themeLight')?.classList.toggle('active', t === 'light');
    document.getElementById('themeNight')?.classList.toggle('active', t === 'night');
    document.getElementById('themeSepia')?.classList.toggle('active', t === 'sepia');
    document.getElementById('themeGreen')?.classList.toggle('active', t === 'green');
  };

  (window as any).setFontSize = function(v: string) {
    if (readerContent) {
      readerContent.style.fontSize = v + 'px';
    }
    const fontSizeVal = document.getElementById('fontSizeVal');
    if (fontSizeVal) fontSizeVal.textContent = v + 'px';
    try {
      localStorage.setItem('dn_fontsize', v);
    } catch (e) {}
  };

  (window as any).setFont = function(t: string) {
    if (readerContent) {
      const fontFamilies: Record<string, string> = {
        sans: '"Noto Sans TC", "PingFang TC", "Microsoft JhengHei", system-ui, sans-serif',
        serif: '"Noto Serif TC", "Songti TC", "PMingLiU", Georgia, serif',
        system: 'system-ui, -apple-system, "Segoe UI", Roboto, sans-serif',
        pingfang: '"PingFang TC", "PingFang SC", "Helvetica Neue", sans-serif',
        jhenghei: '"Microsoft JhengHei", "Microsoft JhengHei UI", sans-serif'
      };
      readerContent.style.fontFamily = fontFamilies[t] || fontFamilies.sans;
    }
    document.getElementById('fontSans')?.classList.toggle('active', t === 'sans');
    document.getElementById('fontSerif')?.classList.toggle('active', t === 'serif');
    document.getElementById('fontSystem')?.classList.toggle('active', t === 'system');
    document.getElementById('fontPingFang')?.classList.toggle('active', t === 'pingfang');
    document.getElementById('fontJhengHei')?.classList.toggle('active', t === 'jhenghei');
    try {
      localStorage.setItem('dn_font', t);
    } catch (e) {}
  };

  (window as any).setLineHeight = function(v: string) {
    if (readerContent) {
      readerContent.style.lineHeight = v;
    }
    const lineHeightVal = document.getElementById('lineHeightVal');
    if (lineHeightVal) lineHeightVal.textContent = v;
    try {
      localStorage.setItem('dn_lineheight', v);
    } catch (e) {}
  };

  (window as any).setParaSpacing = function(v: string) {
    if (readerContent) {
      readerContent.style.setProperty('--reading-paragraph-space', v + 'em');
    }
    const paraSpacingVal = document.getElementById('paraSpacingVal');
    if (paraSpacingVal) paraSpacingVal.textContent = v + 'em';
    try {
      localStorage.setItem('dn_paraspacing', v);
    } catch (e) {}
  };

  (window as any).setTextAlign = function(align: string) {
    if (readerContent) {
      readerContent.style.textAlign = align;
    }
    document.getElementById('alignLeft')?.classList.toggle('active', align === 'left');
    document.getElementById('alignJustify')?.classList.toggle('active', align === 'justify');
    try {
      localStorage.setItem('dn_textalign', align);
    } catch (e) {}
  };

  // ========== TTS (Text-to-Speech) ==========
  let ttsParagraphs: NodeListOf<HTMLParagraphElement> | null = null;

  function initTTS() {
    ttsParagraphs = document.querySelectorAll('#readerContent p');
    const totalPara = document.getElementById('ttsTotalPara');
    if (totalPara) totalPara.textContent = String(ttsParagraphs?.length || 0);
  }

  (window as any).toggleTTS = function() {
    if (state.ttsPlaying) {
      speechSynthesis.cancel();
      state.ttsPlaying = false;
      state.ttsCurrentIdx = 0;
      (window as any).updateTTSIcon();
      (window as any).updateTTSProgress(0);
    } else {
      if (!ttsParagraphs || ttsParagraphs.length === 0) {
        initTTS();
      }
      if (ttsParagraphs && ttsParagraphs.length > 0) {
        speakFrom(state.ttsCurrentIdx);
      }
    }
  };

  (window as any).updateTTSIcon = function() {
    const playIcon = document.getElementById('ttsPlayIcon');
    const pauseIcon = document.getElementById('ttsPauseIcon');
    playIcon?.classList.toggle('hidden', state.ttsPlaying);
    pauseIcon?.classList.toggle('hidden', !state.ttsPlaying);
  };

  (window as any).updateTTSProgress = function(pct: number) {
    const ttsRange = document.getElementById('ttsRange') as HTMLInputElement;
    const currentPara = document.getElementById('ttsCurrentPara');
    const totalPara = document.getElementById('ttsTotalPara');
    
    if (ttsRange) ttsRange.value = String(Math.round(pct * 100));
    if (currentPara) currentPara.textContent = String(state.ttsCurrentIdx + 1);
    if (totalPara && ttsParagraphs) totalPara.textContent = String(ttsParagraphs.length);
  };

  (window as any).setTTSRate = function(v: string) {
    const rateVal = document.getElementById('ttsRateVal');
    if (rateVal) rateVal.textContent = parseFloat(v).toFixed(1) + 'x';
    if (state.ttsUtterance) state.ttsUtterance.rate = parseFloat(v);
  };

  (window as any).setTTSPitch = function(v: string) {
    const pitchVal = document.getElementById('ttsPitchVal');
    if (pitchVal) pitchVal.textContent = parseFloat(v).toFixed(1);
    if (state.ttsUtterance) state.ttsUtterance.pitch = parseFloat(v);
  };

  (window as any).seekTTS = function(val: string) {
    if (!ttsParagraphs || ttsParagraphs.length === 0) return;
    
    const pct = parseInt(val) / 100;
    const targetIdx = Math.min(Math.floor(pct * ttsParagraphs.length), ttsParagraphs.length - 1);
    
    if (state.ttsPlaying) {
      speakFrom(targetIdx);
    } else {
      state.ttsCurrentIdx = targetIdx;
      (window as any).updateTTSProgress(pct);
      highlightParagraph(targetIdx);
    }
  };

  function speakFrom(idx: number) {
    speechSynthesis.cancel();
    
    if (!ttsParagraphs || idx < 0 || idx >= ttsParagraphs.length) {
      state.ttsPlaying = false;
      state.ttsCurrentIdx = 0;
      (window as any).updateTTSIcon();
      (window as any).updateTTSProgress(0);
      clearTTSHighlight();
      return;
    }
    
    state.ttsCurrentIdx = idx;
    
    let txt = '';
    for (let i = idx; i < ttsParagraphs.length; i++) {
      txt += ttsParagraphs[i].textContent + ' ';
    }
    
    state.ttsUtterance = new SpeechSynthesisUtterance(txt);
    state.ttsUtterance.lang = 'zh-TW';
    
    const rateEl = document.getElementById('ttsRate') as HTMLInputElement;
    const pitchEl = document.getElementById('ttsPitch') as HTMLInputElement;
    if (rateEl) state.ttsUtterance.rate = parseFloat(rateEl.value);
    if (pitchEl) state.ttsUtterance.pitch = parseFloat(pitchEl.value);
    
    state.ttsUtterance.onend = () => {
      state.ttsPlaying = false;
      state.ttsCurrentIdx = 0;
      (window as any).updateTTSIcon();
      (window as any).updateTTSProgress(0);
      clearTTSHighlight();
      const ttsRange = document.getElementById('ttsRange') as HTMLInputElement;
      if (ttsRange) ttsRange.value = '0';
    };
    
    state.ttsUtterance.onboundary = (ev) => {
      if (ev.name === 'word' || ev.name === 'sentence') {
        const charPos = ev.charIndex;
        let before = 0;
        let done = idx;
        
        for (let j = idx; j < ttsParagraphs!.length; j++) {
          const plen = ttsParagraphs![j].textContent!.length;
          if (charPos < before + plen + 1) {
            done = j;
            break;
          }
          before += plen + 1;
        }
        
        if (done !== state.ttsCurrentIdx) {
          state.ttsCurrentIdx = done;
          highlightParagraph(done);
        }
        
        if (ttsParagraphs && ttsParagraphs.length > 1) {
          const pct = (done - idx) / (ttsParagraphs.length - 1);
          (window as any).updateTTSProgress(pct);
          const ttsRange = document.getElementById('ttsRange') as HTMLInputElement;
          if (ttsRange) ttsRange.value = String(Math.round(pct * 100));
        }
      }
    };
    
    speechSynthesis.speak(state.ttsUtterance);
    state.ttsPlaying = true;
    (window as any).updateTTSIcon();
    (window as any).updateTTSProgress(0);
    highlightParagraph(idx);
  }

  function highlightParagraph(idx: number) {
    if (!ttsParagraphs) return;
    
    clearTTSHighlight();
    if (idx >= 0 && idx < ttsParagraphs.length) {
      const el = ttsParagraphs[idx];
      el.classList.add('tts-active');
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function clearTTSHighlight() {
    ttsParagraphs?.forEach(p => p.classList.remove('tts-active'));
  }

  // TTS play button
  const ttsPlayBtn = document.getElementById('ttsPlayBtn');
  ttsPlayBtn?.addEventListener('click', () => (window as any).toggleTTS());

  // ========== Reading Statistics ==========
  function initReadingStats() {
    const contentEl = document.getElementById('readerContent');
    const wordCountEl = document.getElementById('wordCountValue');
    const readTimeEl = document.getElementById('readTimeValue');

    if (!contentEl || !wordCountEl || !readTimeEl) return;

    // Calculate word count from all paragraphs
    const paragraphs = contentEl.querySelectorAll('p');
    let totalChars = 0;
    paragraphs.forEach(p => {
      const text = p.textContent || '';
      // Remove spaces and count Chinese characters + letters + numbers
      const chars = text.replace(/\s/g, '').length;
      totalChars += chars;
    });

    // Display word count
    wordCountEl.textContent = String(totalChars);

    // Calculate reading time (300 chars/min for Chinese)
    const readingSpeed = 300; // characters per minute
    const minutes = Math.ceil(totalChars / readingSpeed);
    readTimeEl.textContent = String(minutes);
  }

  // ========== Chapter Preload ==========
  const PRELOAD_KEY = 'preloaded-chapters';
  const MAX_PRELOADS = 3; // Limit to prevent waste

  // Get chapter info from data attributes
  const readerPage = document.querySelector('.reader-page');
  const hasNextChapter = readerPage?.getAttribute('data-has-next') === 'true';

  function preloadNextChapter() {
    // Only preload if there's a next chapter
    if (!hasNextChapter) return;

    try {
      const nextChapterUrl = `${basePath}/book/${novelSlug}/${currentChapter + 1}`;

      // Check if already preloaded
      const preloaded = JSON.parse(localStorage.getItem(PRELOAD_KEY) || '{}');
      if (preloaded[nextChapterUrl]) {
        console.log('✓ Chapter already preloaded:', nextChapterUrl);
        return;
      }

      // Clean up old preloads (keep only last MAX_PRELOADS)
      const keys = Object.keys(preloaded);
      if (keys.length >= MAX_PRELOADS) {
        const oldestKey = keys[0];
        delete preloaded[oldestKey];
      }

      // Use link preload for next chapter (as="document" not needed for HTML)
      const link = document.createElement('link');
      link.rel = 'preload';
      link.href = nextChapterUrl;
      document.head.appendChild(link);

      // Mark as preloaded
      preloaded[nextChapterUrl] = true;
      localStorage.setItem(PRELOAD_KEY, JSON.stringify(preloaded));
      console.log('✓ Preloading next chapter:', nextChapterUrl);
    } catch (e) {
      // Ignore storage errors
    }
  }

  // Smart preload: when user scrolls past 50% or idle for 3s
  let preloadTriggered = false;
  function checkPreload() {
    if (preloadTriggered || !hasNextChapter) return;

    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const progress = docHeight > 0 ? scrollTop / docHeight : 0;

    // Preload when user has read 50% or more
    if (progress >= 0.5) {
      preloadTriggered = true;
      preloadNextChapter();
    }
  }

  // Also preload after idle for 3 seconds (user is likely reading)
  let idleTimeout: ReturnType<typeof setTimeout>;
  function resetIdleTimer() {
    clearTimeout(idleTimeout);
    idleTimeout = setTimeout(() => {
      if (!preloadTriggered) {
        preloadTriggered = true;
        preloadNextChapter();
      }
    }, 3000);
  }

  // Listen to scroll events
  window.addEventListener('scroll', () => {
    checkPreload();
    resetIdleTimer();
  }, { passive: true });

  // Initial check after page loads
  setTimeout(checkPreload, 1000);

  // ========== Initialize ==========
  loadSettings();
  initReadingStats();
  restoreReadingProgress();
  updateProgress();

  // Add data-tts-idx to paragraphs
  document.querySelectorAll('#readerContent p').forEach((p, i) => {
    p.setAttribute('data-tts-idx', String(i));
  });
</script>
