---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { config } from '../../../config';
import { getCollection } from 'astro:content';
import fs from 'fs';
import path from 'path';
import DualImage from '../../../components/DualImage.astro';
import SchemaOrg from '../../../components/SchemaOrg.astro';

export async function getStaticPaths() {
  const novels = await getCollection('novels');
  // Filter to only meta.json entries
  const novelMetadata = novels.filter(n => n.id.endsWith('/meta') && n.data?.synopsis);

  // Build metadata map for all novels
  const allNovelsMeta = {};
  novelMetadata.forEach(n => {
    const s = n.id.replace('/meta', '');
    allNovelsMeta[s] = {
      title: n.data.title,
      author: n.data.author,
      genre: n.data.genre,
      chapters: n.data.totalChapters || n.data.chapters || 1,
      categories: n.data.categories || []
    };
  });

  return novelMetadata.map((novel) => {
    const slug = novel.id.replace('/meta', '');
    const currentCategories = novel.data.categories || [];

    // Find related books (same category, exclude current)
    const related = novelMetadata
      .filter(n => {
        const nSlug = n.id.replace('/meta', '');
        if (nSlug === slug) return false;
        const nCats = n.data.categories || [];
        return nCats.some(c => currentCategories.includes(c));
      })
      .slice(0, 4)
      .map(n => ({
        slug: n.id.replace('/meta', ''),
        title: n.data.title,
        author: n.data.author,
        chapters: n.data.totalChapters || n.data.chapters || 1
      }));

    return {
      params: { novel: slug },
      props: {
        novel: novel.data,
        slug,
        relatedBooks: related,
        allBooksMeta: allNovelsMeta
      }
    };
  });
}

const { novel, slug, relatedBooks = [], allBooksMeta = {} } = Astro.props;
// Check if cover image exists (prefer .webp for performance)
const novelDir = path.join('src/content/novels', slug);
const coverPath = fs.existsSync(path.join(novelDir, 'cover.webp')) ? 'cover.webp' :
               fs.existsSync(path.join(novelDir, 'cover.png')) ? 'cover.png' :
               fs.existsSync(path.join(novelDir, 'cover.jpg')) ? 'cover.jpg' : null;
const coverUrl = coverPath ? config.path('/content/novels/' + slug + '/' + coverPath) : null;
---

<BaseLayout title={`${novel.title} - 小说阁`} activeTab="library">
  <SchemaOrg
    type="Book"
    data={{
      name: novel.title,
      description: novel.synopsis,
      author: novel.author,
      numberOfPages: novel.totalChapters || novel.chapters,
      url: Astro.url.href,
      image: coverUrl
    }}
  />
  <div class="book-detail">
    <!-- Hero Section -->
    <div class="detail-hero">
      <div class="detail-cover">
        {coverUrl ? (
          <DualImage src={coverUrl} alt={`${novel.title}封面`} />
        ) : (
          <div class="css-book-cover" style="width: 120px; height: 170px;">
            <div class="cover-content">
              <span class="cover-title">{novel.title}</span>
              <span class="cover-author">{novel.author}</span>
            </div>
          </div>
        )}
      </div>
      <div class="detail-info">
        <div class="detail-info-row">
          <h1 class="detail-title">{novel.title}</h1>
          <button class="fav-btn-top" id="favBtnTop" title="收藏" aria-label="收藏此小说">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </button>
        </div>
        <p class="detail-author">{novel.author}</p>
        <div class="detail-meta">
          <span>{novel.genre || '都市'}</span>
          <span>{novel.chapters}章</span>
          <span class={`status-tag ${novel.status === '已完結' ? 'done' : 'ongoing'}`}>
            {novel.status || '連載中'}
          </span>
        </div>
        <!-- Rating Section -->
        <div class="detail-rating" id="ratingSection">
          <div class="rating-stars" id="ratingStars">
            {[1, 2, 3, 4, 5].map(star => (
              <button class="star-btn" data-rating={star} aria-label={`評 ${star} 星`}>
                <svg class="star-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              </button>
            ))}
          </div>
          <span class="rating-text" id="ratingText">評分</span>
        </div>
        <!-- Share Button -->
        <button class="share-btn" id="shareBtn" aria-label="分享書籍">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
          <span>分享</span>
        </button>
      </div>
    </div>

    <!-- Synopsis -->
    <div class="synopsis">
      <h3 class="synopsis-title">簡介</h3>
      <p class="synopsis-text">{novel.synopsis || '暂无简介'}</p>
    </div>

    <!-- Tags -->
    {novel.tags && (
      <div class="detail-tags">
        {novel.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <!-- TOC Preview -->
    <div class="toc-preview-section" id="tocPreviewSection">
      <button class="toc-preview-toggle" id="tocPreviewToggle" aria-expanded="false" aria-controls="tocPreviewList">
        <span>目錄預覽</span>
        <svg class="toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <ul class="toc-preview-list" id="tocPreviewList" style="display: none;">
        {Array.from({ length: Math.min(5, novel.totalChapters || novel.chapters || 0) }, (_, i) => i + 1).map((num) => (
          <li>
            <a href={config.path('/book/' + slug + '/' + num)} class="toc-preview-item">
              <span class="toc-chapter">{num}</span>
              <span class="toc-title">第 {num} 章</span>
            </a>
          </li>
        ))}
        {novel.totalChapters > 5 && (
          <li class="toc-more">
            <span>... 共 {novel.totalChapters || novel.chapters} 章</span>
          </li>
        )}
      </ul>
    </div>

    <!-- Chapter List -->
    <div class="chapters-section">
      <h3 class="section-title">目錄</h3>
      <ul class="toc-list">
        {Array.from({ length: (novel.totalChapters || novel.chapters || 0) }, (_, i) => i + 1).map((num) => (
          <li>
            <a href={config.path('/book/' + slug + '/' + num)} class="toc-item">
              <span class="toc-chapter">{num}</span>
              <span class="toc-title">第 {num} 章</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Related Books Section -->
  {relatedBooks.length > 0 && (
    <div class="related-section">
     相關書籍
      <div class="related-grid">
        {relatedBooks.map((book) => (
          <a href={config.path('/book/' + book.slug)} class="related-card">
            <div class="related-cover">
              <div class="css-book-cover" style="width: 100%; height: 100%;">
                <div class="cover-content">
                  <span class="cover-title">{book.title.slice(0, 4)}</span>
                </div>
              </div>
            </div>
            <div class="related-info">
              <span class="related-title">{book.title}</span>
              <span class="related-chapters">{book.chapters} 章</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Comments Section -->
  <div class="comments-section" id="commentsSection">
    <h3 class="comments-title">讀者評論</h3>
    <div class="comment-form">
      <textarea
        id="commentInput"
        class="comment-input"
        placeholder="写下你的评论..."
        rows="3"
        aria-label="評論內容"
      ></textarea>
      <button class="comment-submit" id="commentSubmit" type="button">
        發表
      </button>
    </div>
    <div class="comments-list" id="commentsList">
      <!-- Comments rendered client-side -->
    </div>
  </div>
</div>

  <!-- Sticky CTA -->
  <div class="sticky-cta">
     <a href={config.path('/book/' + slug + '/1')} class="btn-primary">

      开始阅读
    </a>
    <button class="btn-secondary" id="favBtn" aria-label="收藏此小说">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  </div>
</BaseLayout>

<style>
  .book-detail {
    padding-top: var(--spacing-4);
  }

  .detail-hero {
    display: flex;
    gap: var(--spacing-8);
    padding: var(--spacing-8);
    background: linear-gradient(135deg, var(--bg-base) 0%, rgba(253, 251, 247, 0.8) 50%, var(--bg-base) 100%);
    border-bottom: 1px solid var(--color-border-light);
    border-left: 3px solid var(--color-accent);
  }

  .detail-cover {
    flex-shrink: 0;
    position: relative;
    width: 120px;
    height: 170px;
    overflow: hidden;
  }

  .css-book-cover {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-300);
    border-radius: var(--radius-sm);
    overflow: hidden;
    font-family: var(--font-serif);
    box-shadow: var(--shadow-md);
  }

  .css-book-cover::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: rgba(0, 0, 0, 0.15);
    z-index: 1;
  }

  .css-book-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 40%, rgba(0,0,0,0.05) 100%);
    pointer-events: none;
  }

  .cover-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-3);
    color: var(--color-white);
  }

  .cover-title {
    font-size: 18px;
    font-weight: var(--font-semibold);
    color: var(--color-white);
    line-height: 1.4;
  }

  .cover-author {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.85);
    margin-top: var(--spacing-1);
  }

  .detail-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--spacing-2);
  }

  .detail-info-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--spacing-3);
  }

  .detail-info-row .detail-title {
    flex: 1;
  }

  .fav-btn-top {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    cursor: pointer;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    transition: all var(--t-fast);
  }

  .fav-btn-top:hover {
    background: rgba(163, 145, 113, 0.1);
    color: var(--color-accent);
  }

  .fav-btn-top:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .fav-btn-top svg {
    width: 24px;
    height: 24px;
  }

  .fav-btn-top.favorited {
    color: var(--color-accent);
  }

  .fav-btn-top.favorited svg[fill="currentColor"] {
    fill: var(--color-accent);
  }

  .detail-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--text-dark);
    letter-spacing: 0.02em;
    font-family: var(--font-serif);
  }

  .detail-author {
    font-size: var(--text-base);
    color: var(--text-muted);
    font-weight: var(--font-normal);
  }

  .detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .status-tag {
    padding: var(--spacing-1) var(--spacing-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
  }

  .status-tag.ongoing {
    background: var(--accent);
    color: var(--color-white);
  }

  /* Rating Section */
  .detail-rating {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-3);
  }

  .rating-stars {
    display: flex;
    gap: 2px;
  }

  .star-btn {
    background: none;
    border: none;
    padding: 2px;
    cursor: pointer;
    color: var(--color-border);
    transition: color 0.15s, transform 0.15s;
  }

  .star-btn:hover {
    transform: scale(1.1);
  }

  .star-btn.active {
    color: #f59e0b;
  }

  .star-btn.filled {
    color: #f59e0b;
  }

  .star-icon {
    fill: currentColor;
  }

  .rating-text {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* Share Button */
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    margin-top: var(--spacing-2);
    padding: var(--spacing-2) var(--spacing-3);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-xs);
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .share-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(163, 145, 113, 0.05);
  }

  .share-btn:active {
    transform: scale(0.98);
  }

  .status-tag.done {
    background: var(--color-success);
    color: var(--color-white);
  }

  .synopsis {
    padding: var(--spacing-8);
    background: var(--bg-base);
    margin-top: var(--spacing-6);
  }

  .synopsis-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-dark);
    margin-bottom: var(--spacing-3);
  }

  .synopsis-text {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.8;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    padding: var(--spacing-6);
    background: var(--bg-base);
    margin-top: var(--spacing-6);
  }

  .tag {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--bg-outer);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  /* TOC Preview */
  .toc-preview-section {
    margin-top: var(--spacing-4);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .toc-preview-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--spacing-4);
    background: var(--bg-base);
    border: none;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--text-dark);
    cursor: pointer;
    transition: background var(--t-fast);
  }

  .toc-preview-toggle:hover {
    background: var(--bg-hover);
  }

  .toc-preview-toggle .toggle-icon {
    transition: transform var(--t-fast);
  }

  .toc-preview-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
  }

  .toc-preview-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--bg-outer);
  }

  .toc-preview-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-3) var(--spacing-4);
    text-decoration: none;
    color: var(--text-dark);
    transition: background var(--t-fast);
  }

  .toc-preview-item:hover {
    background: rgba(163, 145, 113, 0.08);
  }

  .toc-preview-item .toc-chapter {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-base);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .toc-preview-item .toc-title {
    font-size: var(--text-sm);
  }

  .toc-more {
    padding: var(--spacing-2) var(--spacing-4);
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .chapters-section {
    padding: var(--spacing-6);
    background: var(--bg-base);
    margin-top: var(--spacing-2);
    padding-bottom: 100px;
  }

  .chapters-section .section-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-dark);
    margin-bottom: var(--spacing-4);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-3);
  }

  .toc-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-3);
    background: var(--bg-outer);
    border-radius: var(--radius-sm);
    transition: all var(--t-normal);
    text-decoration: none;
    color: inherit;
  }

  .toc-item:hover {
    background: rgba(163, 145, 113, 0.08);
    transform: translateX(4px);
  }

  .toc-item:active {
    transform: scale(0.98);
  }

  .toc-item:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .toc-chapter {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-outer);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
    touch-action: manipulation;
  }

  .toc-title {
    font-size: var(--text-sm);
    color: var(--text-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Related Books Section */
  .related-section {
    padding: var(--spacing-6) var(--spacing-4);
    margin-top: var(--spacing-4);
    border-top: 1px solid var(--color-border-light);
  }

  .related-section h3 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    margin-bottom: var(--spacing-4);
    color: var(--text-dark);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-3);
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .related-card {
    display: block;
    text-decoration: none;
    background: var(--bg-card);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    transition: all var(--t-normal);
  }

  @media (hover: hover) {
    .related-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
      border-color: var(--accent);
    }
  }

  .related-cover {
    aspect-ratio: 3/4;
    background: var(--color-primary-300);
  }

  .related-cover .css-book-cover {
    border-radius: 0;
  }

  .related-cover .cover-title {
    font-size: var(--text-sm);
  }

  .related-info {
    padding: var(--spacing-2);
  }

  .related-title {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--text-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .related-chapters {
    font-size: 10px;
    color: var(--text-muted);
  }

  /* Comments Section */
  .comments-section {
    padding: var(--spacing-6) var(--spacing-4);
    margin-top: var(--spacing-4);
    border-top: 1px solid var(--color-border-light);
  }

  .comments-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-dark);
    margin-bottom: var(--spacing-4);
  }

  .comment-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-4);
  }

  .comment-input {
    width: 100%;
    padding: var(--spacing-3);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-family: inherit;
    resize: vertical;
    min-height: 80px;
    background: var(--bg-base);
    color: var(--text-dark);
    transition: border-color var(--t-fast);
  }

  .comment-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .comment-input::placeholder {
    color: var(--text-muted);
  }

  .comment-submit {
    align-self: flex-end;
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--accent);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .comment-submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .comment-submit:active {
    transform: scale(0.98);
  }

  .comments-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .comment-item {
    padding: var(--spacing-3);
    background: var(--bg-base);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }

  .comment-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-2);
  }

  .comment-date {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .comment-delete {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: var(--text-xs);
    cursor: pointer;
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    transition: all var(--t-fast);
  }

  .comment-delete:hover {
    color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }

  .comment-text {
    font-size: var(--text-sm);
    color: var(--text-dark);
    line-height: 1.6;
    word-break: break-word;
  }

  .comments-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: var(--text-sm);
    padding: var(--spacing-4);
  }

  /* Sticky CTA */
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 25;
    /* Solid background fallback + gradient overlay for consistent visibility */
    background: var(--bg-base);
    background-image: linear-gradient(to top, var(--bg-base) 60%, transparent 100%);
    padding: var(--spacing-4) var(--spacing-8);
    padding-bottom: calc(var(--spacing-4) + env(safe-area-inset-bottom, 8px));
    display: flex;
    gap: var(--spacing-4);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
  }

  /* Desktop: constrain to content width */
  @media (min-width: 768px) {
    .sticky-cta {
      max-width: 1100px;
      margin: 0 auto;
    }
  }

  .btn-primary {
    flex: 1;
    padding: var(--spacing-4);
    border-radius: var(--radius-lg);
    color: var(--color-white);
    text-align: center;
    font-weight: var(--font-medium);
    font-size: var(--text-base);
    min-height: 48px;
    background: var(--accent);
    border: none;
    transition: all var(--t-normal);
    cursor: pointer;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-primary:hover {
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .btn-primary:active {
    transform: scale(0.98);
  }

  .btn-primary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .btn-secondary {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    color: var(--text-dark);
    background: var(--bg-base);
    font-weight: var(--font-medium);
    transition: all var(--t-normal);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-secondary:hover {
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .btn-secondary:active {
    transform: scale(0.98);
  }

  .btn-secondary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script is:inline>
  // Get novel slug from URL - decode if URL-encoded
  const pathSlug = window.location.pathname.split('/book/')[1]?.split('/')[0] || '';
  const novelSlug = decodeURIComponent(pathSlug);
  
  // Favorite functionality - check both top and bottom buttons
  const favBtnTop = document.getElementById('favBtnTop') as HTMLButtonElement | null;
  const favBtnBottom = document.getElementById('favBtn') as HTMLButtonElement | null;
  
  const handleFavorite = () => {
    if (!novelSlug) return;
    
    const favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
    
    // Decode all favorites for comparison
    const decodedFavorites = favorites.map((f: string) => decodeURIComponent(f));
    const index = decodedFavorites.indexOf(novelSlug);
    const isFav = index > -1;
    
    if (isFav) {
      // Remove the encoded version
      favorites.splice(index, 1);
      favBtnTop?.querySelector('svg')?.setAttribute('fill', 'none');
      favBtnBottom?.querySelector('svg')?.setAttribute('fill', 'none');
    } else {
      // Add decoded version
      favorites.push(novelSlug);
      favBtnTop?.querySelector('svg')?.setAttribute('fill', 'currentColor');
      favBtnBottom?.querySelector('svg')?.setAttribute('fill', 'currentColor');
    }
    
    localStorage.setItem('favorites', JSON.stringify(favorites));
  };
  
  // Initialize: check if already favorited
  if (novelSlug) {
    const favorites = JSON.parse(localStorage.getItem('favorites') || '[]');
    const decodedFavorites = favorites.map((f: string) => decodeURIComponent(f));
    const isFav = decodedFavorites.includes(novelSlug);
    if (isFav) {
      favBtnTop?.querySelector('svg')?.setAttribute('fill', 'currentColor');
      favBtnBottom?.querySelector('svg')?.setAttribute('fill', 'currentColor');
    }
  }
  
  // Add click handlers
  favBtnTop?.addEventListener('click', handleFavorite);
  favBtnBottom?.addEventListener('click', handleFavorite);

  // ===== Rating System =====
  const RATING_KEY = 'zen-novel-ratings';
  const ratingStars = document.querySelectorAll<HTMLButtonElement>('.star-btn');
  const ratingText = document.getElementById('ratingText');

  function getRating(bookId: string): number {
    try {
      const ratings = JSON.parse(localStorage.getItem(RATING_KEY) || '{}');
      return ratings[bookId] || 0;
    } catch {
      return 0;
    }
  }

  function setRating(bookId: string, rating: number): void {
    try {
      const ratings = JSON.parse(localStorage.getItem(RATING_KEY) || '{}');
      ratings[bookId] = rating;
      localStorage.setItem(RATING_KEY, JSON.stringify(ratings));
    } catch {}
  }

  function updateStars(rating: number): void {
    ratingStars.forEach(star => {
      const starRating = parseInt(star.dataset.rating || '0');
      star.classList.toggle('filled', starRating <= rating);
      star.classList.toggle('active', starRating <= rating);
    });
    if (ratingText && rating > 0) {
      ratingText.textContent = `${rating} 星`;
    } else if (ratingText) {
      ratingText.textContent = '評分';
    }
  }

  // Initialize rating display
  if (novelSlug) {
    const currentRating = getRating(novelSlug);
    updateStars(currentRating);
  }

  // Add click handlers for stars
  ratingStars.forEach(star => {
    star.addEventListener('click', () => {
      if (!novelSlug) return;
      const rating = parseInt(star.dataset.rating || '0');
      setRating(novelSlug, rating);
      updateStars(rating);

      // Bounce animation
      star.style.transform = 'scale(1.3)';
      setTimeout(() => star.style.transform = '', 150);
    });
  });

  // ===== Share Button =====
  const shareBtn = document.getElementById('shareBtn');

  shareBtn?.addEventListener('click', async () => {
    const url = window.location.href;
    const title = document.querySelector('.detail-title')?.textContent || '小說';

    try {
      if (navigator.share) {
        // Use native share API
        await navigator.share({ title, url });
      } else {
        // Fallback: copy to clipboard
        await navigator.clipboard.writeText(url);
        shareBtn.querySelector('span')?.textContent = '已複製!';
        setTimeout(() => {
          shareBtn.querySelector('span')?.textContent = '分享';
        }, 2000);
      }
    } catch (err) {
      // Fallback for browsers without clipboard API
      const textArea = document.createElement('textarea');
      textArea.value = url;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      shareBtn.querySelector('span')?.textContent = '已複製!';
      setTimeout(() => {
        shareBtn.querySelector('span')?.textContent = '分享';
      }, 2000);
    }
  });

  // ===== Comments System =====
  const COMMENTS_KEY = 'zen-novel-comments';
  const commentInput = document.getElementById('commentInput') as HTMLTextAreaElement | null;
  const commentSubmit = document.getElementById('commentSubmit');
  const commentsList = document.getElementById('commentsList');

  function getComments(bookId: string): Array<{ date: string; text: string; id: number }> {
    try {
      const allComments = JSON.parse(localStorage.getItem(COMMENTS_KEY) || '{}');
      return allComments[bookId] || [];
    } catch {
      return [];
    }
  }

  function saveComments(bookId: string, comments: Array<{ date: string; text: string; id: number }>): void {
    try {
      const allComments = JSON.parse(localStorage.getItem(COMMENTS_KEY) || '{}');
      allComments[bookId] = comments;
      localStorage.setItem(COMMENTS_KEY, JSON.stringify(allComments));
    } catch {}
  }

  function formatDate(dateStr: string): string {
    const date = new Date(dateStr);
    const now = new Date();
    const diffMs = now.getTime() - date.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 1) return '刚刚';
    if (diffMins < 60) return `${diffMins} 分钟前`;
    if (diffHours < 24) return `${diffHours} 小时前`;
    if (diffDays < 7) return `${diffDays} 天前`;
    return date.toLocaleDateString('zh-TW', { month: 'short', day: 'numeric' });
  }

  function renderComments(): void {
    if (!commentsList || !novelSlug) return;

    const comments = getComments(novelSlug);

    if (comments.length === 0) {
      commentsList.innerHTML = '<div class="comments-empty">暂无评论，快来发表第一条评论吧！</div>';
      return;
    }

    // Sort by newest first
    const sortedComments = [...comments].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

    commentsList.innerHTML = sortedComments.map(comment => `
      <div class="comment-item" data-id="${comment.id}">
        <div class="comment-header">
          <span class="comment-date">${formatDate(comment.date)}</span>
          <button class="comment-delete" onclick="deleteComment(${comment.id})">删除</button>
        </div>
        <div class="comment-text">${escapeHtml(comment.text)}</div>
      </div>
    `).join('');
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Make deleteComment available globally
  (window as unknown as { deleteComment: (id: number) => void }).deleteComment = function(id: number) {
    if (!novelSlug) return;
    const comments = getComments(novelSlug).filter(c => c.id !== id);
    saveComments(novelSlug, comments);
    renderComments();
  };

  // Initialize comments
  if (novelSlug) {
    renderComments();
  }

  // Handle comment submission
  commentSubmit?.addEventListener('click', () => {
    if (!novelSlug || !commentInput) return;

    const text = commentInput.value.trim();
    if (!text) return;

    const comments = getComments(novelSlug);
    const newComment = {
      id: Date.now(),
      date: new Date().toISOString(),
      text: text.slice(0, 500) // Limit to 500 characters
    };

    comments.push(newComment);
    saveComments(novelSlug, comments);

    commentInput.value = '';
    renderComments();
  });

  // Allow Ctrl+Enter to submit
  commentInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
      commentSubmit?.click();
    }
  });

  // ===== TOC Preview Toggle =====
  const tocPreviewToggle = document.getElementById('tocPreviewToggle');
  const tocPreviewList = document.getElementById('tocPreviewList');

  tocPreviewToggle?.addEventListener('click', () => {
    const isExpanded = tocPreviewToggle.getAttribute('aria-expanded') === 'true';
    tocPreviewToggle.setAttribute('aria-expanded', String(!isExpanded));
    if (tocPreviewList) {
      tocPreviewList.style.display = isExpanded ? 'none' : 'block';
    }
  });
</script>

<style is:global>
  @keyframes fav-bounce {
    0% { transform: scale(1); }
    30% { transform: scale(1.08); }
    60% { transform: scale(0.98); }
    100% { transform: scale(1); }
  }
</style>