---
import BaseLayout from '../layouts/BaseLayout.astro';
import { config } from '../config';
---

<BaseLayout title="我的 - 小说阁" activeTab="my">
  <div class="my-page">
    <!-- Profile Header -->
    <div class="profile-header">
      <div class="profile-avatar" id="profileAvatar">
        <span>讀</span>
      </div>
      <div class="profile-info">
        <div class="profile-name" id="profileName">Reader</div>
        <button class="edit-name-btn" id="editNameBtn" title="編輯暱稱">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
          </svg>
        </button>
        <div class="profile-stats" id="profileStats">0 本收藏 · 0 章閱讀</div>
        <div class="streak-badge" id="streakBadge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
          <span id="streakCount">0</span> 天
        </div>
      </div>
    </div>

    <!-- Edit Name Modal -->
    <div class="edit-name-modal" id="editNameModal">
      <div class="edit-name-overlay"></div>
      <div class="edit-name-dialog">
        <div class="edit-name-header">
          <h3>編輯暱稱</h3>
          <button class="close-btn" id="closeEditName">×</button>
        </div>
        <div class="edit-name-body">
          <input type="text" id="nameInput" class="name-input" placeholder="輸入暱稱" maxlength="20">
        </div>
        <div class="edit-name-footer">
          <button class="cancel-btn" id="cancelName">取消</button>
          <button class="save-btn" id="saveName">儲存</button>
        </div>
      </div>
    </div>

    <!-- Create List Modal -->
    <div class="edit-name-modal" id="createListModal">
      <div class="edit-name-overlay"></div>
      <div class="edit-name-dialog">
        <div class="edit-name-header">
          <h3>创建书单</h3>
          <button class="close-btn" id="closeCreateList">×</button>
        </div>
        <div class="edit-name-body">
          <input type="text" id="listNameInput" class="name-input" placeholder="书单名称" maxlength="20">
        </div>
        <div class="edit-name-footer">
          <button class="cancel-btn" id="cancelCreateList">取消</button>
          <button class="save-btn" id="saveCreateList">创建</button>
        </div>
      </div>
    </div>

    <!-- Quick Resume Section -->
    <div id="quick-resume" class="my-section quick-resume-section" style="display: none;">
      <div class="section-header">
        <h2>继续阅读</h2>
      </div>
      <div class="quick-resume-card">
        <div class="qr-cover" id="qrCover"></div>
        <div class="qr-info">
          <div class="qr-title" id="qrTitle"></div>
          <div class="qr-chapter" id="qrChapter"></div>
          <div class="qr-progress">
            <div class="qr-progress-bar"><div class="qr-progress-fill" id="qrProgressFill"></div></div>
            <span class="qr-progress-text" id="qrProgressText"></span>
          </div>
        </div>
        <a href="#" class="qr-continue-btn" id="qrContinue">继续阅读</a>
      </div>
    </div>

    <!-- Reading Lists Section -->
    <div class="my-section">
      <div class="section-header">
        <h2>我的书单</h2>
        <button class="add-list-btn" id="addListBtn" title="创建书单">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>
      </div>
      <div id="readingLists" class="list-container">
        <!-- Reading lists rendered client-side -->
      </div>
    </div>

    <!-- Favorites Section -->
    <div class="my-section">
      <div class="section-header">
        <h2>我的收藏</h2>
      </div>
      <div id="favorites" class="list-container">
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <p>尚未收藏任何小说</p>
        </div>
      </div>
    </div>

    <!-- History Section -->
    <div class="my-section">
      <div class="section-header">
        <h2>阅读记录</h2>
      </div>
      <div id="history" class="list-container">
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <p>尚无阅读记录</p>
        </div>
      </div>
    </div>

    <!-- Settings Section -->
    <div class="my-section">
      <div class="section-header">
        <h2>设置</h2>
      </div>
      <div class="settings-list">
        <!-- Theme Toggle -->
        <div class="setting-row">
          <div class="setting-label">主题</div>
          <div class="theme-toggle">
            <button class="theme-btn active" data-theme="light">浅色</button>
            <button class="theme-btn" data-theme="sepia">護眼</button>
            <button class="theme-btn" data-theme="night">夜間</button>
          </div>
        </div>
        <button class="settings-item" id="clear-favorites">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
          <span>清空收藏</span>
        </button>
        <button class="settings-item" id="clear-history">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="3 6 5 6 21 6"></polyline>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
          </svg>
          <span>清空歷史記錄</span>
        </button>
      </div>
    </div>

    <!-- About Section -->
    <div class="my-section">
      <div class="about-section">
        <span>小说阁 v1.0</span>
      </div>
    </div>

    <!-- Legal Links -->
    <div class="legal-links">
      <a href={config.path('/legal/privacy')} class="legal-link">隐私政策</a>
      <span class="legal-divider">|</span>
      <a href={config.path('/legal/terms')} class="legal-link">服务条款</a>
    </div>
  </div>
</BaseLayout>

<style>
/* Mobile-First - Single Column Layout */
  .my-page {
    min-height: 100vh;
    padding-bottom: var(--spacing-8);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    padding: var(--spacing-2);
    max-width: 100%;
    margin: 0 auto;
    overflow-x: hidden;
  }

  .page-header {
    display: none;
  }

  /* Profile Header - Full Width on Mobile */
  .profile-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    padding: var(--spacing-3);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    width: 100%;
  }

  .profile-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .profile-avatar span {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-white);
    font-family: var(--font-serif);
  }

  .profile-info {
    flex: 1;
    min-width: 0;
  }

  .profile-name {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    font-family: var(--font-serif);
    color: var(--text-dark);
    display: inline;
  }

  .edit-name-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-left: var(--spacing-1);
    padding: 4px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-sm);
    vertical-align: middle;
    transition: all var(--t-fast);
  }

  .edit-name-btn:hover {
    color: var(--accent);
    background: rgba(163, 145, 113, 0.1);
  }

  .profile-stats {
    font-size: 10px;
    color: var(--text-muted);
  }

  .streak-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: var(--spacing-1);
    padding: 2px 8px;
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: var(--font-medium);
    color: white;
  }

  .streak-badge svg {
    opacity: 0.9;
  }

  /* My Sections - Match Library Card Pattern */
  .my-section {
    width: 100%;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    box-shadow: var(--bento-shadow);
    padding: var(--spacing-4);
    transition: var(--bento-transition);
  }

  @media (hover: hover) {
    .my-section:hover {
      box-shadow: var(--bento-shadow-hover);
    }
  }

  .section-header {
    padding: var(--spacing-2) 0;
    margin-bottom: var(--spacing-4);
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: var(--spacing-3);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .section-header h2 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--text-dark);
  }

  .add-list-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .add-list-btn:hover {
    background: rgba(163, 145, 113, 0.1);
    color: var(--accent);
    border-color: var(--accent);
  }

  /* Tablet Layout */
  @media (min-width: 640px) {
    .my-page {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      padding: var(--bento-gap);
      max-width: 1100px;
    }
    .profile-header {
      grid-column: span 3;
    }
    .my-section:nth-of-type(1) {
      grid-column: span 2;
    }
  }

  /* Desktop Layout */
  @media (min-width: 1024px) {
    .my-page {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--bento-gap-lg);
      padding: var(--bento-gap-lg);
    }
    .profile-header {
      grid-column: span 3;
    }
    .my-section:nth-of-type(1) {
      grid-column: span 2;
    }
    .my-section:nth-of-type(2) {
      grid-column: span 1;
    }
  }

  @media (min-width: 1280px) {
    .my-page {
      grid-template-columns: repeat(4, 1fr);
    }
    .my-section:nth-of-type(1),
    .my-section:nth-of-type(2),
    .my-section:nth-of-type(3) {
      grid-column: span 2;
    }
  }

  /* User Stats - Bento Style */
  .user-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-12);
    padding: var(--spacing-8);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--bento-radius);
    box-shadow: var(--bento-shadow);
    margin: var(--bento-gap);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-1);
  }

  .stat-num {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--text-dark);
    font-family: var(--font-serif);
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .stat-divider {
    width: 1px;
    height: var(--spacing-10);
    background: var(--color-border-light);
  }

  /* Quick Resume Section */
  .quick-resume-section {
    padding: 0 var(--spacing-4);
  }

  .quick-resume-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    padding: var(--spacing-4);
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .qr-cover {
    width: 50px;
    height: 70px;
    background: rgba(255,255,255,0.2);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .qr-cover span {
    font-size: var(--text-xs);
    color: var(--color-white);
    font-family: var(--font-serif);
  }

  .qr-info {
    flex: 1;
    min-width: 0;
  }

  .qr-title {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-white);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .qr-chapter {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.8);
    margin-top: 2px;
  }

  .qr-progress {
    display: flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-2);
  }

  .qr-progress-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.3);
    border-radius: 2px;
    overflow: hidden;
  }

  .qr-progress-fill {
    height: 100%;
    background: var(--color-white);
    border-radius: 2px;
    transition: width var(--t-normal);
  }

  .qr-progress-text {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.8);
    min-width: 32px;
  }

  .qr-continue-btn {
    padding: var(--spacing-2) var(--spacing-4);
    background: var(--color-white);
    color: var(--color-accent);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--t-fast);
  }

  .qr-continue-btn:hover {
    transform: scale(1.02);
    box-shadow: var(--shadow-sm);
  }

  .qr-continue-btn:active {
    transform: scale(0.98);
  }

  /* List Container */
  .list-container {
    padding: 0 var(--spacing-4);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-12);
    color: var(--text-muted);
    text-align: center;
  }

  .empty-state svg {
    margin-bottom: var(--spacing-3);
    opacity: 0.5;
  }

  .empty-state p {
    font-size: var(--text-sm);
  }

  .empty-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-4);
    padding: var(--spacing-3) var(--spacing-5);
    background: var(--color-accent);
    color: var(--color-white);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--t-normal);
  }

  .empty-cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  .empty-cta:active {
    transform: scale(0.98);
  }

  /* Settings List */
  .settings-list {
    background: var(--bg-base);
    margin: 0 var(--spacing-4);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
  }

  .settings-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    width: 100%;
    padding: var(--spacing-4);
    min-height: 44px;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-border-light);
    font-size: var(--text-base);
    color: var(--text-dark);
    cursor: pointer;
    transition: all var(--t-normal);
    text-align: left;
  }

  .settings-item:last-child {
    border-bottom: none;
  }

  .settings-item:hover {
    background: rgba(163, 145, 113, 0.08);
  }

  .settings-item:active {
    transform: scale(0.98);
    background: rgba(163, 145, 113, 0.12);
  }

  .settings-item svg {
    color: var(--text-muted);
  }

  /* Setting Row */
  .setting-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-4);
    border-bottom: 1px solid var(--color-border-light);
    flex-wrap: wrap;
    gap: var(--spacing-2);
  }

  .setting-label {
    font-size: var(--text-base);
    color: var(--text-dark);
  }

  /* Theme Toggle */
  .theme-toggle {
    display: flex;
    background: var(--color-bg-outer);
    border-radius: var(--radius-md);
    padding: var(--spacing-1);
    border: 1px solid var(--color-border-light);
    flex-wrap: wrap;
  }

  .theme-btn {
    padding: var(--spacing-2) var(--spacing-3);
    border: none;
    background: transparent;
    font-size: var(--text-xs);
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all var(--t-fast);
  }

  .theme-btn.active {
    background: var(--color-accent);
    color: var(--color-white);
  }

  .theme-btn:not(.active):hover {
    background: rgba(163, 145, 113, 0.08);
  }

  /* Legal Links */
  .legal-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-12);
    color: var(--text-muted);
    flex-wrap: wrap;
    width: 100%;
    text-align: center;
  }

  /* About Section */
  .about-section {
    text-align: center;
    padding: var(--spacing-12);
    font-size: var(--text-sm);
    color: var(--text-muted);
    opacity: 0.6;
    width: 100%;
  }

  .legal-link {
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--t-fast);
  }

  .legal-link:hover {
    color: var(--accent);
  }

  .legal-divider {
    opacity: 0.5;
  }

  /* Edit Name Modal */
  .edit-name-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
  }

  .edit-name-modal.active {
    display: block;
  }

  .edit-name-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .edit-name-dialog {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 85%;
    max-width: 320px;
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .edit-name-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-4);
    border-bottom: 1px solid var(--color-border-light);
  }

  .edit-name-header h3 {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
  }

  .edit-name-header .close-btn {
    background: none;
    border: none;
    font-size: var(--text-xl);
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 8px;
  }

  .edit-name-body {
    padding: var(--spacing-4);
  }

  .name-input {
    width: 100%;
    padding: var(--spacing-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    background: var(--bg-outer);
    color: var(--text-dark);
  }

  .name-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(207, 185, 151, 0.15);
  }

  .edit-name-footer {
    display: flex;
    gap: var(--spacing-3);
    padding: var(--spacing-4);
    border-top: 1px solid var(--color-border-light);
  }

  .edit-name-footer button {
    flex: 1;
    padding: var(--spacing-3);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    cursor: pointer;
    transition: all var(--t-normal);
  }

  .edit-name-footer .cancel-btn {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--text-secondary);
  }

  .edit-name-footer .cancel-btn:hover {
    background: var(--bg-hover);
  }

  .edit-name-footer .save-btn {
    background: var(--accent);
    border: none;
    color: white;
  }

  .edit-name-footer .save-btn:hover {
    background: var(--accent-hover);
  }

  /* History Item */
  :global(.history-item) {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    padding: var(--spacing-3);
    background: var(--bg-base);
    border-radius: var(--radius-sm);
    margin-bottom: var(--spacing-2);
    text-decoration: none;
    color: var(--text-dark);
    transition: all var(--t-normal);
    border: 1px solid var(--color-border-light);
  }

  :global(.history-item .item-link) {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    flex: 1;
    min-width: 0;
    text-decoration: none;
    color: inherit;
  }

  :global(.history-item:hover .item-link) {
    color: inherit;
  }

  :global(.history-item:hover) {
    border-color: var(--accent);
    transform: translateX(var(--spacing-1));
  }

  :global(.history-item .mini-cover) {
    width: var(--spacing-10);
    height: var(--spacing-6);
    background: var(--color-primary-300);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  :global(.history-item .item-info) {
    flex: 1;
    min-width: 0;
  }

  :global(.history-item .item-title) {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.history-item .item-chapter) {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--spacing-1);
  }

  :global(.history-item .item-progress) {
    height: 3px;
    background: var(--color-border-light);
    border-radius: 2px;
    margin-top: var(--spacing-1);
    overflow: hidden;
  }

  :global(.history-item .item-progress-fill) {
    height: 100%;
    background: var(--color-accent);
    border-radius: 2px;
  }

  :global(.history-item .item-time) {
    font-size: var(--text-xs-sm);
    color: var(--text-muted);
    margin-top: 2px;
    opacity: 0.7;
  }

  :global(.history-item .item-remove) {
    padding: var(--spacing-2);
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-sm);
    opacity: 0;
    transition: all var(--t-fast);
  }

  :global(.history-item:hover .item-remove) {
    opacity: 1;
  }

  :global(.history-item .item-remove:hover) {
    background: rgba(163, 145, 113, 0.1);
    color: var(--color-error);
  }

  /* Responsive - Tablet (640px+) */
  @media (min-width: 640px) {
    .user-stats {
      max-width: 600px;
      margin: 0 auto var(--spacing-12);
    }

    .list-container {
      max-width: 800px;
      margin: 0 auto;
    }

    .settings-list {
      max-width: 600px;
      margin: 0 auto;
    }

    .page-header {
      text-align: center;
      padding: var(--spacing-12) var(--spacing-6);
    }

    .section-header {
      max-width: 800px;
      margin: 0 auto var(--spacing-4);
    }
  }

  /* Responsive - Desktop (1024px+) */
  @media (min-width: 1024px) {
    .user-stats {
      max-width: 500px;
      padding: var(--spacing-12);
    }

    .settings-list {
      max-width: 500px;
    }

    .page-header h1 {
      font-size: var(--text-4xl);
    }
  }
</style>

<script>
// Use config.base from import.meta.env at build time (Astro injects this)
// For runtime, use window.__configBase__ from data-base-path attribute
const rawBasePath = (window as any).__configBase__ || '/';
const BASE_PATH = rawBasePath === '/' ? '' : rawBasePath;

  const novelsData: Record<string, { title: string; chapters: number }> = {
    '維港深淵': { title: '維港深淵', chapters: 20 },
    '佛系廚神': { title: '佛系廚神', chapters: 18 },
    '一茶一禪-海岸線的寧靜': { title: '一茶一禪', chapters: 50 },
    '一茶一禪': { title: '一茶一禪', chapters: 50 },
    '萬界直播系統': { title: '萬界直播系統', chapters: 130 },
    '万界直播系统': { title: '萬界直播系統', chapters: 130 }
  };

  function createMiniCover(title: string) {
    return `<div class="mini-cover"><span style="font-size: var(--text-xs-sm); color: var(--color-white);">${title.slice(0, 2)}</span></div>`;
  }

  function getRelativeTime(timestamp: number) {
    const now = Date.now();
    const diff = now - timestamp;
    const minutes = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);
    if (minutes < 1) return '刚刚';
    if (minutes < 60) return `${minutes} 分钟前`;
    if (hours < 24) return `${hours} 小时前`;
    if (days < 2) return '昨天';
    return `${days} 天前`;
  }

  // Expose functions to global scope for onclick handlers
  (window as any).removeFromHistory = function(id: string) {
    const h = JSON.parse(localStorage.getItem('history') || '[]');
    const filtered = h.filter((item: { id: string }) => decodeURIComponent(item.id) !== decodeURIComponent(id));
    localStorage.setItem('history', JSON.stringify(filtered));
    loadHistory();
    loadQuickResume();
  };

  (window as any).removeFromFavorites = function(id: string) {
    const fav = JSON.parse(localStorage.getItem('favorites') || '[]');
    const filtered = fav.filter((i: string) => decodeURIComponent(i) !== decodeURIComponent(id));
    localStorage.setItem('favorites', JSON.stringify(filtered));
    loadFavorites();
    loadQuickResume();
  };

  function loadQuickResume() {
    const section = document.getElementById('quick-resume');
    if (!section) return;
    try {
      const h = JSON.parse(localStorage.getItem('history') || '[]');
      if (h.length === 0) {
        section.style.display = 'none';
        return;
      }
      const last = h[0];
      const data = novelsData[last.id] || { title: last.id, chapters: 0 };
      const progress = last.chapter ? Math.round((last.chapter / data.chapters) * 100) : 0;
      
      const cover = document.getElementById('qrCover');
      const title = document.getElementById('qrTitle');
      const chapter = document.getElementById('qrChapter');
      const fill = document.getElementById('qrProgressFill');
      const text = document.getElementById('qrProgressText');
      const btn = document.getElementById('qrContinue');
      
      if (cover) cover.innerHTML = `<span>${data.title.slice(0, 2)}</span>`;
      if (title) title.textContent = data.title;
      if (chapter) chapter.textContent = last.chapter ? `第 ${last.chapter} 章 / ${data.chapters} 章` : '未开始阅读';
      if (fill) fill.style.width = `${progress}%`;
      if (text) text.textContent = `${progress}%`;
      if (btn) (btn as HTMLAnchorElement).href = `${BASE_PATH}/book/${last.id}${last.chapter ? '/' + last.chapter : ''}`;
      
      section.style.display = 'block';
    } catch (e) {
      if (section) section.style.display = 'none';
    }
  }

  function loadFavorites() {
    try {
      const raw = localStorage.getItem('favorites');
      let favData = JSON.parse(raw || '[]');
      
      // Clean up: decode IDs
      favData = favData.map((item: string) => decodeURIComponent(item));
      
      // Remove duplicates
      const seen = new Set();
      favData = favData.filter((item: string) => {
        if (seen.has(item)) return false;
        seen.add(item);
        return true;
      });
      
      const container = document.getElementById('favorites');
      const countEl = document.getElementById('favCount');
      
      if (countEl) countEl.textContent = String(favData.length);
      
      if (!container) return;
      
      if (favData.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
            <p>尚未收藏任何小说</p>
            <a href="${BASE_PATH}/library" class="empty-cta">探索书库</a>
          </div>`;
      } else {
        container.innerHTML = favData.map((id: string) => {
          const data = novelsData[id] || { title: id, chapters: 0 };
          return `
            <div class="history-item">
              <a href="${BASE_PATH}/book/${id}" class="item-link">
                ${createMiniCover(data.title)}
                <div class="item-info">
                  <div class="item-title">${data.title}</div>
                  <div class="item-chapter">${data.chapters} 章</div>
                </div>
              </a>
              <button class="item-remove" onclick="removeFromFavorites('${id}'); event.stopPropagation();" title="移除收藏">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6L6 18M6 6l12 12"></path>
                </svg>
              </button>
            </div>`;
        }).join('');
      }
    } catch (e) {
      console.error(e);
    }
  }

  function loadHistory() {
    try {
      const raw = localStorage.getItem('history');
      let historyData = JSON.parse(raw || '[]');
      
      // Clean up: decode IDs and filter malformed entries
      historyData = historyData.map((item: any) => {
        if (typeof item === 'string') {
          return { id: decodeURIComponent(item), chapter: 1, timestamp: Date.now() };
        }
        if (item && item.id) {
          return { 
            id: decodeURIComponent(item.id), 
            chapter: item.chapter || 1, 
            timestamp: item.timestamp || Date.now() 
          };
        }
        return null;
      }).filter((item: any) => item && item.id);
      
      // Remove duplicates
      const seen = new Set();
      historyData = historyData.filter((item: any) => {
        if (seen.has(item.id)) return false;
        seen.add(item.id);
        return true;
      });
      
      const container = document.getElementById('history');
      
      // Update profile stats
      const fav = JSON.parse(localStorage.getItem('favorites') || '[]');
      const totalChapters = historyData.reduce((sum: number, item: { chapter?: number }) => sum + (item.chapter || 0), 0);
      const statsEl = document.getElementById('profileStats');
      if (statsEl) {
        statsEl.textContent = `${fav.length} 本收藏 · ${totalChapters} 章阅读`;
      }
      
      if (!container) return;
      
      if (historyData.length === 0) {
        container.innerHTML = `
          <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <p>尚无阅读记录</p>
            <a href="${BASE_PATH}/library" class="empty-cta">开始阅读</a>
          </div>`;
      } else {
        container.innerHTML = historyData.slice(0, 10).map((item: { id: string; chapter?: number; timestamp?: number }) => {
          const data = novelsData[item.id] || { title: item.id, chapters: 0 };
          const progress = item.chapter && data.chapters ? Math.round((item.chapter / data.chapters) * 100) : 0;
          const timeAgo = item.timestamp ? getRelativeTime(item.timestamp) : '';
          return `
            <div class="history-item">
              <a href="${BASE_PATH}/book/${item.id}${item.chapter ? '/' + item.chapter : ''}" class="item-link">
                ${createMiniCover(data.title)}
                <div class="item-info">
                  <div class="item-title">${data.title}</div>
                  <div class="item-chapter">${item.chapter ? '第 ' + item.chapter + ' 章 · ' + progress + '%' : '未开始阅读'}</div>
                  ${item.chapter ? `<div class="item-progress"><div class="item-progress-fill" style="width:${progress}%"></div></div>` : ''}
                  ${timeAgo ? `<div class="item-time">${timeAgo}</div>` : ''}
                </div>
              </a>
              <button class="item-remove" onclick="removeFromHistory('${item.id}'); event.stopPropagation();" title="移除">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6L6 18M6 6l12 12"></path>
                </svg>
              </button>
            </div>`;
        }).join('');
      }
    } catch (e) {
      console.error(e);
    }
  }

  document.getElementById('clear-favorites')?.addEventListener('click', () => {
    if (confirm('确定要清空所有收藏嗎？')) {
      localStorage.removeItem('favorites');
      loadFavorites();
      loadQuickResume();
    }
  });

  document.getElementById('clear-history')?.addEventListener('click', () => {
    if (confirm('确定要清空所有阅读记录嗎？')) {
      localStorage.removeItem('history');
      loadHistory();
      loadQuickResume();
    }
  });

  // Load on page init
  // Force reload
  loadFavorites();
  loadHistory();
  loadQuickResume();

  // ===== Reading Streak =====
  const STREAK_KEY = 'zen-novel-reading-streak';
  const streakCountEl = document.getElementById('streakCount');

  function getStreak(): { count: number; lastReadDate: string | null } {
    try {
      const data = JSON.parse(localStorage.getItem(STREAK_KEY) || '{"count":0,"lastReadDate":null}');
      return data;
    } catch {
      return { count: 0, lastReadDate: null };
    }
  }

  function updateStreak(): void {
    const today = new Date().toISOString().split('T')[0];
    const streak = getStreak();

    if (streak.lastReadDate === today) {
      // Already read today, no update needed
      return;
    }

    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate() - 1);
    const yesterdayStr = yesterday.toISOString().split('T')[0];

    let newCount = 1;
    if (streak.lastReadDate === yesterdayStr) {
      // Read yesterday, continue streak
      newCount = streak.count + 1;
    }
    // If last read was before yesterday, reset to 1

    const updatedStreak = {
      count: newCount,
      lastReadDate: today
    };

    try {
      localStorage.setItem(STREAK_KEY, JSON.stringify(updatedStreak));
    } catch {}

    if (streakCountEl) {
      streakCountEl.textContent = String(newCount);
    }
  }

  // Check and update streak when page loads
  updateStreak();

  // Also update streak when reading (on chapter page)
  const progressData = localStorage.getItem('reading_progress');
  if (progressData) {
    try {
      const progress = JSON.parse(progressData);
      if (Object.keys(progress).length > 0) {
        updateStreak();
      }
    } catch {}
  }

  // Initialize streak display
  const initialStreak = getStreak();
  if (streakCountEl) {
    streakCountEl.textContent = String(initialStreak.count);
  }

  // ===== Edit Nickname =====
  const NICKNAME_KEY = 'zen-novel-nickname';
  const editNameBtn = document.getElementById('editNameBtn');
  const editNameModal = document.getElementById('editNameModal');
  const closeEditName = document.getElementById('closeEditName');
  const cancelName = document.getElementById('cancelName');
  const saveName = document.getElementById('saveName');
  const nameInput = document.getElementById('nameInput') as HTMLInputElement | null;
  const profileName = document.getElementById('profileName');
  const profileAvatar = document.getElementById('profileAvatar');

  function getNickname(): string {
    try {
      return localStorage.getItem(NICKNAME_KEY) || 'Reader';
    } catch {
      return 'Reader';
    }
  }

  function setNickname(name: string): void {
    try {
      localStorage.setItem(NICKNAME_KEY, name);
    } catch {}
  }

  function updateNicknameDisplay(): void {
    const nickname = getNickname();
    if (profileName) profileName.textContent = nickname;
    if (profileAvatar) {
      const avatarSpan = profileAvatar.querySelector('span');
      if (avatarSpan) avatarSpan.textContent = nickname.charAt(0).toUpperCase();
    }
  }

  // Initialize nickname on load
  updateNicknameDisplay();

  function openEditModal() {
    if (editNameModal && nameInput) {
      nameInput.value = getNickname();
      editNameModal.classList.add('active');
      setTimeout(() => nameInput?.focus(), 100);
    }
  }

  function closeEditModal() {
    if (editNameModal) {
      editNameModal.classList.remove('active');
    }
  }

  function saveNickname() {
    const newName = nameInput?.value.trim() || 'Reader';
    setNickname(newName);
    updateNicknameDisplay();
    closeEditModal();
  }

  editNameBtn?.addEventListener('click', openEditModal);
  closeEditName?.addEventListener('click', closeEditModal);
  cancelName?.addEventListener('click', closeEditModal);
  saveName?.addEventListener('click', saveNickname);

  editNameModal?.querySelector('.edit-name-overlay')?.addEventListener('click', closeEditModal);

  nameInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      saveNickname();
    } else if (e.key === 'Escape') {
      closeEditModal();
    }
  });

  // ===== Reading Lists =====
  const READING_LISTS_KEY = 'zen-novel-reading-lists';
  const addListBtn = document.getElementById('addListBtn');
  const createListModal = document.getElementById('createListModal');
  const closeCreateList = document.getElementById('closeCreateList');
  const cancelCreateList = document.getElementById('cancelCreateList');
  const saveCreateList = document.getElementById('saveCreateList');
  const listNameInput = document.getElementById('listNameInput') as HTMLInputElement | null;

  function getReadingLists(): Array<{ id: string; name: string; books: string[] }> {
    try {
      return JSON.parse(localStorage.getItem(READING_LISTS_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function saveReadingLists(lists: Array<{ id: string; name: string; books: string[] }>): void {
    try {
      localStorage.setItem(READING_LISTS_KEY, JSON.stringify(lists));
    } catch {}
  }

  function renderReadingLists(): void {
    const container = document.getElementById('readingLists');
    if (!container) return;

    const lists = getReadingLists();

    if (lists.length === 0) {
      container.innerHTML = `
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
          </svg>
          <p>暂无书单</p>
          <button class="empty-cta" onclick="document.getElementById('addListBtn').click()">创建书单</button>
        </div>`;
      return;
    }

    container.innerHTML = lists.map(list => `
      <div class="history-item reading-list-item">
        <a href="${BASE_PATH}/my?list=${encodeURIComponent(list.id)}" class="item-link">
          <div class="mini-cover" style="background: var(--color-accent);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <div class="item-info">
            <div class="item-title">${escapeHtml(list.name)}</div>
            <div class="item-chapter">${list.books.length} 本书</div>
          </div>
        </a>
        <button class="item-remove" onclick="deleteReadingList('${list.id}'); event.stopPropagation();" title="删除书单">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12"></path>
          </svg>
        </button>
      </div>`).join('');
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  (window as any).deleteReadingList = function(id: string) {
    if (!confirm('确定要删除这个书单吗？')) return;
    const lists = getReadingLists().filter(l => l.id !== id);
    saveReadingLists(lists);
    renderReadingLists();
  };

  function openCreateListModal() {
    if (createListModal && listNameInput) {
      listNameInput.value = '';
      createListModal.classList.add('active');
      setTimeout(() => listNameInput?.focus(), 100);
    }
  }

  function closeCreateListModal() {
    if (createListModal) {
      createListModal.classList.remove('active');
    }
  }

  function createList() {
    const name = listNameInput?.value.trim();
    if (!name) return;

    const lists = getReadingLists();
    lists.push({
      id: Date.now().toString(),
      name: name.slice(0, 20),
      books: []
    });
    saveReadingLists(lists);
    closeCreateListModal();
    renderReadingLists();
  }

  addListBtn?.addEventListener('click', openCreateListModal);
  closeCreateList?.addEventListener('click', closeCreateListModal);
  cancelCreateList?.addEventListener('click', closeCreateListModal);
  saveCreateList?.addEventListener('click', createList);

  createListModal?.querySelector('.edit-name-overlay')?.addEventListener('click', closeCreateListModal);

  listNameInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      createList();
    } else if (e.key === 'Escape') {
      closeCreateListModal();
    }
  });

  // Initialize reading lists
  renderReadingLists();

  // Theme Toggle
  (function initTheme() {
    const saved = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', saved);
    document.querySelectorAll('.theme-btn').forEach((btn: Element) => {
      btn.classList.toggle('active', btn.getAttribute('data-theme') === saved);
    });
  })();

  document.querySelectorAll('.theme-btn').forEach((btn: Element) => {
    btn.addEventListener('click', () => {
      const theme = btn.getAttribute('data-theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      document.querySelectorAll('.theme-btn').forEach((b: Element) => {
        b.classList.toggle('active', b.getAttribute('data-theme') === theme);
      });
    });
  });
</script>